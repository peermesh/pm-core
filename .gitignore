# Security & Credentials (NEVER COMMIT)
*.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
credentials.*
secrets.*
*.password
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*

# Secrets directory (keep structure, ignore actual secrets)
secrets/*
!secrets/.gitkeep
!secrets/README.md

# Backup Files (Auto-added by Smart Commit)
*.backup
*.backup-*
*.bak
*.orig
*~
.*.swp
.*.swo
#*#

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS Files
.DS_Store
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes
ehthumbs.db

# Editor/IDE
.vscode/
.idea/
*.iml
*.sublime-*
.project
.classpath
.settings/

# Temporary & Cache
*.tmp
*.temp
.cache/
*.pid

# Build Artifacts (if project adds build tooling later)
node_modules/
dist/
build/
__pycache__/
*.pyc
target/

# Nested Git Repositories (should be submodules)
.dev/reference-repos/nself/

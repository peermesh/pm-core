# ==============================================================
# PKI Module Configuration
# ==============================================================
# Copy this file to .env and customize for your deployment.
#
# Required secrets are stored in configs/ directory:
#   - configs/ca_password (auto-generated on install)
#   - configs/provisioner_password (auto-generated on install)
#
# Documentation: modules/pki/README.md
# ==============================================================

# ==============================================================
# Certificate Authority Settings
# ==============================================================

# Name of the Certificate Authority (shown in certificate issuer)
PKI_CA_NAME=PeerMesh Internal CA

# DNS name for the CA server (used in CA certificate SAN)
PKI_CA_DNS_NAME=ca.pmdl.local

# Address and port for the CA API server
# Format: :port or host:port
PKI_CA_ADDRESS=:9000

# ==============================================================
# Certificate Durations
# ==============================================================
# Duration format: <number>h (hours) or <number>d (days)
# Examples: 720h (30 days), 2160h (90 days), 8760h (1 year)

# Default duration for service certificates
PKI_CERT_DURATION=720h

# Time before expiry to trigger certificate renewal
# Recommended: 2/3 of certificate duration
PKI_RENEWAL_WINDOW=480h

# Root CA certificate duration (10 years default)
# WARNING: Changing this after CA initialization has no effect
PKI_ROOT_CERT_DURATION=87600h

# ==============================================================
# Storage Paths
# ==============================================================

# Path for CA data (keys, configuration, database)
PKI_STORAGE_PATH=/var/lib/pki

# Path where service certificates are stored
PKI_CERTS_OUTPUT_PATH=/var/lib/pki/certs

# ==============================================================
# ACME Protocol
# ==============================================================

# Enable ACME protocol for automated certificate provisioning
# This allows services to request certificates programmatically
PKI_ACME_ENABLED=true

# Name of the default provisioner for certificate issuance
PKI_PROVISIONER_NAME=pmdl-provisioner

# ==============================================================
# Automatic Renewal
# ==============================================================

# Enable automatic certificate renewal
# When enabled, the cert-renewer service monitors certificates
# and renews them before expiry
PKI_AUTO_RENEW_ENABLED=true

# ==============================================================
# Service Presets
# ==============================================================
# Default DNS names for common services

# PostgreSQL service certificate DNS name
PKI_POSTGRES_SERVICE_NAME=postgres.pmdl.local

# Redis service certificate DNS name
PKI_REDIS_SERVICE_NAME=redis.pmdl.local

# ==============================================================
# Security Notes
# ==============================================================
#
# 1. Secret Management:
#    - CA password and provisioner password are auto-generated
#    - They are stored in configs/ with 600 permissions
#    - NEVER commit these files to version control
#
# 2. Root CA Protection:
#    - The root CA key is critical infrastructure
#    - It's stored in the pmdl_pki_ca_data Docker volume
#    - Consider backing up this volume securely
#
# 3. Certificate Renewal:
#    - Automatic renewal handles most cases
#    - Monitor the dashboard for expiring certificates
#    - Renew root CA before expiry (years in advance)
#
# 4. Offline Operation:
#    - This module works completely offline (local-first)
#    - No external CA dependencies
#    - All certificates are issued locally
#
# ==============================================================

# SOPS Configuration Template - Mozilla Secrets Operations
# ============================================================
# This is a TEMPLATE file. Copy and customize for your environment:
#   cp .sops.yaml.example .sops.yaml
#
# Commit .sops.yaml with PUBLIC recipients only (never private keys).
# Keep .sops.yaml.example as onboarding reference.

---

# Global Configuration
# ====================
# These settings apply to all files unless overridden by path-specific rules below

creation_rule: ".sops.yaml:creation_rule"  # Comments reference this file's sections

# ============================================================
# ENVIRONMENT-SPECIFIC RULES
# ============================================================
# SOPS matches files against these rules in ORDER (top to bottom)
# First matching rule applies - more specific rules should come first

rules:

  # ==================== PRODUCTION ====================
  # MOST RESTRICTIVE - Requires explicit key from operations team
  # Path pattern: secrets/*production* or secrets/prod/*
  #
  # HOW TO USE:
  # 1. Only ops team members should have prod private keys
  # 2. Prod keys stored in HSM or secure key management system
  # 3. Production secrets are encrypted with 1-2 keys (limited access)
  # 4. Rotate prod keys quarterly
  #
  # PATH REGEX EXPLANATION:
  #   ^secrets/.*prod.*$ matches:
  #     - secrets/prod/ (any file in prod dir)
  #     - secrets/production/ (any file in production dir)
  #     - secrets/db.prod.yaml (prod in filename)
  #   Does NOT match: secrets/staging/ or secrets/development/
  #
  - path_regex: ^secrets/.*prod(uction)?/.*$
    key_groups:
      - age:
          # Production Key - Ops Team Only
          # Format: age public key (starts with "age1")
          # Replace with actual ops team key
          # Generate: age-keygen -o age_prod.txt
          # Then extract public key and add here
          - age1ops_team_prod_key_placeholder_replace_me_0000000000000

    # This rule can optionally reference a KMS key for additional layer
    # Uncomment if using AWS KMS for prod
    # kms:
    #   - arn: arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012
    #     context:
    #       Department: Operations
    #       Environment: production

  # ==================== STAGING ====================
  # MEDIUM RESTRICTION - Team access, but still limited
  # Path pattern: secrets/*staging* or secrets/stage/*
  #
  # HOW TO USE:
  # 1. All team members testing releases should have staging keys
  # 2. Keys stored in team password manager (1Password, Vault, etc)
  # 3. Staging secrets encrypted with 3-5 team member keys
  # 4. Rotate staging keys every 6 months
  # 5. Audit access: track who decrypted staging secrets
  #
  # AGE KEY MANAGEMENT (see "Understanding Age Keys" section below):
  # - Each team member has a private key (kept secret)
  # - Public key listed here allows their private key to decrypt
  # - Multiple public keys = multiple people can decrypt same secrets
  # - Add new team member: run age-keygen, add public key, commit .sops.yaml
  # - Remove team member: remove their public key, re-encrypt files
  #
  - path_regex: ^secrets/.*stag(ing)?/.*$
    key_groups:
      - age:
          # Staging Keys - Engineering Team
          # Add one public key per team member who needs staging access
          # When adding member: 1) Get their public key 2) Add here 3) Commit
          # When removing member: 1) Remove key 2) Run 'sops updatekeys' 3) Commit
          - age1eng_team_member1_public_key_placeholder_0000000000001
          - age1eng_team_member2_public_key_placeholder_0000000000002
          - age1eng_team_member3_public_key_placeholder_0000000000003

  # ==================== DEVELOPMENT ====================
  # LEAST RESTRICTIVE - Full team access
  # Path pattern: secrets/*dev* or secrets/development/*
  #
  # HOW TO USE:
  # 1. All developers should have their own dev key
  # 2. Keys stored locally in ~/.config/sops/age/ directory
  # 3. Development secrets encrypted with all developer keys
  # 4. Everyone can modify dev secrets (still audited by SOPS)
  # 5. Rotate dev keys yearly or when developer leaves team
  #
  # Best Practice:
  # - Each dev generates their own key with: age-keygen -o ~/.config/sops/age/dev.txt
  # - Share only the PUBLIC key (age1...) with team
  # - Private key never leaves their machine
  # - SOPS automatically finds private key in ~/.config/sops/age/
  #
  - path_regex: ^secrets/.*dev(elopment)?/.*$
    key_groups:
      - age:
          # Development Keys - All Engineers
          # Each developer adds their public key here
          # Format: age-keygen to generate, extract age1... part
          - age1dev_team_member1_public_key_placeholder_00000000000001
          - age1dev_team_member2_public_key_placeholder_00000000000002
          - age1dev_team_member3_public_key_placeholder_00000000000003
          - age1dev_team_member4_public_key_placeholder_00000000000004
          - age1dev_team_member5_public_key_placeholder_00000000000005

  # ==================== DEFAULT (catch-all) ====================
  # Fallback rule for any secrets files not matched above
  # Includes: secrets/common/* or other unmatched paths
  #
  # HOW TO USE:
  # 1. Applied if file doesn't match prod/staging/dev patterns
  # 2. Typically used for shared configuration that multiple environments use
  # 3. Use most restrictive keys (production team)
  #
  - path_regex: ^secrets/.*$
    key_groups:
      - age:
          # Default Secrets - Operations Team
          - age1ops_team_prod_key_placeholder_replace_me_0000000000000

---

# ============================================================
# UNDERSTANDING AGE KEYS
# ============================================================
# Age is a modern encryption tool. Each person has a keypair:
#
# PRIVATE KEY (secret - never share):
#   Format: age-6Ke...RgSo#<redacted>
#   Location: ~/.config/sops/age/dev.txt (or similar)
#   Protects: Your ability to decrypt secrets
#   If lost: You cannot decrypt secrets, need team to re-encrypt
#   If stolen: Attacker can decrypt all your secrets
#
# PUBLIC KEY (safe to share - add to .sops.yaml):
#   Format: age1abc123def456...xyz
#   Used in: .sops.yaml and commit history
#   Protects: Allows your private key to decrypt specific files
#   Compromise: Low risk - only tells what you CAN decrypt, not HOW
#
# HOW DECRYPTION WORKS:
#   1. You run: sops secrets/dev/db.yaml
#   2. SOPS finds your private key at ~/.config/sops/age/dev.txt
#   3. SOPS checks if your public key is in .sops.yaml for that file
#   4. If match: Your private key decrypts the file
#   5. If no match: SOPS error - you don't have access
#
# GENERATING YOUR KEY:
#   # First time only
#   mkdir -p ~/.config/sops/age
#   age-keygen -o ~/.config/sops/age/dev.txt
#   cat ~/.config/sops/age/dev.txt  # Your private key (keep secret!)
#   grep "^# public key" ~/.config/sops/age/dev.txt | cut -d' ' -f4
#   # Copy that age1... public key and give to team lead

---

# ============================================================
# PATH REGEX PATTERNS - QUICK REFERENCE
# ============================================================
# Examples of path patterns and what they match:
#
# PATTERN: ^secrets/.*prod.*$
# MATCHES:
#   - secrets/prod/db.yaml ✓
#   - secrets/production/tls.yaml ✓
#   - secrets/db.prod.yaml ✓
#   - secrets/prod/ (any file in directory) ✓
# DOESN'T MATCH:
#   - secrets/staging/db.yaml ✗
#   - secrets/development/db.yaml ✗
#   - secrets/db.backup ✗
#
# PATTERN: ^secrets/.*stag.*$
# MATCHES: secrets/staging/*, secrets/stage/*, secrets/app.staging.yaml
#
# PATTERN: ^secrets/.*dev.*$
# MATCHES: secrets/dev/*, secrets/development/*, secrets/db.dev.yaml
#
# PATTERN: ^secrets/.*$
# MATCHES: Any file in secrets/ directory (catch-all)
#
# MORE COMPLEX PATTERNS:
#   ^secrets/(prod|production)/.*$   # Prod directory OR production directory
#   ^secrets/.*/api-.*\.yaml$        # API keys in any environment
#   ^secrets/.*-secrets-.*\.yaml$    # Any file with "-secrets-" in name
#   ^secrets/(prod|stg|dev)/certs.*$ # certs files in prod, stg, or dev dirs
#
# Tips:
#   - ^ = start of path
#   - $ = end of path
#   - .* = any characters (zero or more)
#   - | = OR operator
#   - () = grouping
#   - Patterns are case-sensitive

---

# ============================================================
# ADDING NEW TEAM MEMBERS
# ============================================================
#
# STEP 1: New member generates their key
#   mkdir -p ~/.config/sops/age
#   age-keygen -o ~/.config/sops/age/dev.txt
#   cat ~/.config/sops/age/dev.txt
#   # Copy the line: "# public key: age1abc123..."
#
# STEP 2: Member shares public key with team lead
#   Slack/Email: "My age public key is: age1abc123def456..."
#   IMPORTANT: Public key only, not the whole file!
#
# STEP 3: Team lead updates this file
#   Edit this .sops.yaml.example (and committed .sops.yaml)
#   Add new public key under appropriate environment section
#   Save and commit: git add .sops.yaml && git commit -m "Add Jane Doe to dev keys"
#
# STEP 4: Re-encrypt existing secrets (optional)
#   If you want them to decrypt existing files immediately:
#   sops updatekeys secrets/dev/db.yaml
#   This reads the .sops.yaml rules and updates encryption
#   Without this: They can decrypt NEW secrets but not existing ones
#
# STEP 5: They can now decrypt
#   sops secrets/dev/db.yaml
#   (Their private key at ~/.config/sops/age/dev.txt will work)

---

# ============================================================
# REMOVING TEAM MEMBERS
# ============================================================
#
# STEP 1: Remove their public key
#   Edit .sops.yaml
#   Delete the line with their public key
#   Commit: git add .sops.yaml && git commit -m "Remove John's dev keys"
#
# STEP 2: Re-encrypt all their secrets
#   # For development secrets
#   sops updatekeys secrets/dev/*.yaml
#   # For staging secrets
#   sops updatekeys secrets/staging/*.yaml
#   # Commit updated files
#   git add secrets/ && git commit -m "Update secret encryption after team change"
#
# STEP 3: They no longer have access
#   Their private key will no longer decrypt any files
#   (Even though they still have it on their machine)

---

# ============================================================
# BEST PRACTICES
# ============================================================
#
# SECURITY:
#   ✓ Commit .sops.yaml to version control (shows who can decrypt what)
#   ✓ NEVER commit actual secrets or private keys
#   ✓ Private keys only on developer machines (~/.config/sops/age/)
#   ✓ Rotate keys when team members leave
#   ✓ Audit who decrypts production secrets
#
# KEY MANAGEMENT:
#   ✓ Use separate keys for prod/staging/dev (least privilege)
#   ✓ Production: minimal keys (ops team only)
#   ✓ Staging: team keys (everyone can test)
#   ✓ Development: all developers have keys (fast iteration)
#   ✓ Backup private keys (passphrase-protected, offline storage)
#
# WORKING WITH SOPS:
#   ✓ Edit: sops secrets/dev/db.yaml (opens in $EDITOR)
#   ✓ View: sops -d secrets/dev/db.yaml (print decrypted, read-only)
#   ✓ Create: SOPS_AGE_RECIPIENTS=age1xxx sops secrets/dev/new.yaml
#   ✓ Update recipients: sops updatekeys secrets/dev/*.yaml (when keys change)
#   ✓ Diff: sops diff secrets/dev/db.yaml (shows actual changes, not noise)

---

# ============================================================
# ENVIRONMENT VARIABLES (Optional)
# ============================================================
#
# Set these in your shell or CI/CD pipeline to control SOPS behavior:
#
# SOPS_AGE_RECIPIENTS=age1ops_key SOPS_AGE_RECIPIENTS_FILE=...
#   Controls which key SOPS uses for encryption (usually auto-detected)
#
# SOPS_KMS_ARN=arn:aws:kms:...
#   For AWS KMS integration (not needed for age-only setup)
#
# SOPS_YAML_KEYS=tag.environment,tag.application
#   Encrypt specific YAML keys instead of entire file
#
# Set in CI/CD:
#   export SOPS_AGE_KEY_FILE=/run/secrets/age-key
#   sops -d secrets/prod/config.yaml > /etc/config.yaml

---

# ============================================================
# TROUBLESHOOTING
# ============================================================
#
# PROBLEM: "permission denied" or "failed to decrypt"
#   CAUSE: Your public key isn't in .sops.yaml for that file
#   FIX: Check that your age1... key is listed under correct environment
#       Ask team lead to add your key and run: sops updatekeys file.yaml
#
# PROBLEM: "No matching private key found"
#   CAUSE: Private key not at ~/.config/sops/age/
#   FIX: Run: age-keygen -o ~/.config/sops/age/dev.txt
#       Or check SOPS_AGE_KEY_FILE environment variable
#
# PROBLEM: File shows encrypted values but I need decrypted version
#   CAUSE: File is still encrypted (normal in git)
#   FIX: Run: sops secrets/dev/file.yaml (opens decrypted in editor)
#       Or: sops -d secrets/dev/file.yaml (prints decrypted, read-only)
#
# PROBLEM: Team member can't decrypt even after adding their key
#   CAUSE: Existing files weren't re-encrypted with new key
#   FIX: Run: sops updatekeys secrets/dev/*.yaml
#       (Reads .sops.yaml and updates encryption on all files)
#
# PROBLEM: .sops.yaml isn't being picked up
#   CAUSE: Not in right directory or named wrong
#   FIX: Must be named exactly: .sops.yaml (with dot prefix)
#       Must be in project root or parent directory
#       SOPS searches upward: current dir -> parent -> grandparent...

---

# ============================================================
# COMMON WORKFLOWS
# ============================================================
#
# ADD DATABASE PASSWORD (dev):
#   $ sops secrets/dev/db.yaml
#   # Editor opens, add: password: "mypassword"
#   # Save and close editor
#   # File is automatically encrypted
#   $ git add secrets/dev/db.yaml && git commit -m "Add dev DB password"
#
# READ PRODUCTION CREDENTIAL (ops only):
#   $ sops -d secrets/prod/api-keys.yaml | grep API_KEY
#   # Only works if ops member running this (key in their .sops.yaml)
#
# UPDATE STAGING KEYS (after new team member joins):
#   $ cat .sops.yaml.example > .sops.yaml  # refresh with new member's key
#   $ sops updatekeys secrets/staging/*.yaml
#   $ git add .sops.yaml secrets/staging/ && git commit -m "Add staging keys"
#
# CI/CD: DECRYPT FOR DEPLOYMENT
#   # In your CI/CD pipeline (GitHub Actions, GitLab CI, etc)
#   $ export SOPS_AGE_KEY_FILE=/run/secrets/deployment_key
#   $ sops -d secrets/prod/config.yaml | docker config create app_config -
#   # Now your app has decrypted secrets at runtime

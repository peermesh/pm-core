# ==============================================================
# LibreChat Environment Configuration
# ==============================================================
# Copy this file to .env and configure for your deployment
#
# Usage:
#   cp .env.example .env
#   nano .env
# ==============================================================

# ==============================================================
# Required Configuration
# ==============================================================

# Your domain (used by Traefik for routing)
DOMAIN=example.com

# MongoDB password for librechat user
# (should match secrets/mongodb_librechat_password)
MONGODB_LIBRECHAT_PASSWORD=

# ==============================================================
# AI Provider API Keys
# ==============================================================
# Configure at least one provider
# For production, use secret files instead of environment variables

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google AI (Gemini)
GOOGLE_API_KEY=

# Azure OpenAI (optional - requires additional config)
AZURE_API_KEY=
# AZURE_OPENAI_API_INSTANCE_NAME=
# AZURE_OPENAI_API_DEPLOYMENT_NAME=
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ==============================================================
# Local Models (Optional)
# ==============================================================

# Ollama base URL (if running local models)
# OLLAMA_BASE_URL=http://ollama:11434

# ==============================================================
# Search (Optional)
# ==============================================================

# Meilisearch configuration (for conversation search)
# MEILI_HOST=http://meilisearch:7700
# MEILI_MASTER_KEY=

# ==============================================================
# Registration Settings
# ==============================================================

# Allow new user registration
ALLOW_REGISTRATION=true

# Allow login without email verification
ALLOW_UNVERIFIED_EMAIL_LOGIN=true

# ==============================================================
# Secrets Checklist
# ==============================================================
# Ensure these secret files exist before starting:
#
# Required:
#   ./secrets/librechat_db_password     - PostgreSQL password
#   ./secrets/mongodb_librechat_password - MongoDB password
#   ./secrets/librechat_creds_key       - Encryption key (hex, 32 chars)
#   ./secrets/librechat_creds_iv        - Encryption IV (hex, 16 chars)
#   ./secrets/librechat_jwt_secret      - JWT signing secret
#   ./secrets/oidc_client_librechat     - OIDC client secret
#
# Generate secrets:
#   openssl rand -base64 32 > secrets/librechat_db_password
#   openssl rand -base64 32 > secrets/mongodb_librechat_password
#   openssl rand -hex 32 > secrets/librechat_creds_key
#   openssl rand -hex 16 > secrets/librechat_creds_iv
#   openssl rand -base64 64 > secrets/librechat_jwt_secret
#   openssl rand -base64 32 > secrets/oidc_client_librechat
#
# ==============================================================

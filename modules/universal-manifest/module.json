{
  "$schema": "../../foundation/schemas/module.schema.json",

  "id": "universal-manifest",
  "version": "0.1.0",
  "name": "Universal Manifest Module",
  "description": "Cross-cutting identity document infrastructure for the PeerMesh ecosystem. Provides manifest CRUD, facet registry with per-module write authorization, Ed25519 signing/verification, and a self-hosted UMID resolver.",

  "author": {
    "name": "PeerMesh Team"
  },
  "license": "MIT",
  "repository": "https://github.com/peermesh/peermesh-core",
  "tags": ["identity", "manifest", "signing", "resolver", "facets", "ed25519"],

  "foundation": {
    "minVersion": "1.0.0"
  },

  "requires": {
    "connections": [
      {
        "type": "database",
        "providers": ["postgres"],
        "required": true,
        "alias": "um-db",
        "config": {
          "database": "universal_manifest",
          "poolSize": 10,
          "timeout": 30000
        }
      },
      {
        "type": "eventbus",
        "providers": ["redis", "nats"],
        "required": false,
        "alias": "um-events"
      }
    ],
    "modules": [],
    "securityServices": []
  },

  "provides": {
    "connections": [
      {
        "type": "custom",
        "provider": "universal-manifest-api",
        "alias": "um-api",
        "surface": "shared",
        "access": "read-write",
        "contractVersion": "0.1.0"
      }
    ],
    "events": [
      "um.manifest.created",
      "um.manifest.updated",
      "um.manifest.revoked",
      "um.facet.written",
      "um.manifest.verified",
      "um.manifest.resolved"
    ],
    "securityServices": []
  },

  "security": {
    "enforcementMode": "warn",
    "identity": {
      "required": false,
      "credentialType": "any"
    },
    "encryption": {
      "dataAtRest": "preferred",
      "transitEncryption": "tls",
      "keyPurposes": ["signing"]
    },
    "contract": {
      "network": {
        "access": "proxy-external"
      },
      "filesystemAccess": {
        "accessLevel": "own-directory-only"
      }
    }
  },

  "dashboard": {
    "displayName": "Universal Manifest",
    "icon": "fingerprint",
    "routes": [
      {
        "path": "/universal-manifest",
        "nav": {
          "label": "Universal Manifest",
          "icon": "fingerprint",
          "order": 30
        }
      }
    ],
    "statusWidget": {
      "size": "medium",
      "order": 30
    }
  },

  "lifecycle": {
    "install": {
      "script": "./hooks/install.sh",
      "timeout": 120,
      "retries": 1
    },
    "start": {
      "script": "./hooks/start.sh",
      "timeout": 60
    },
    "stop": {
      "script": "./hooks/stop.sh",
      "timeout": 30
    },
    "uninstall": "./hooks/uninstall.sh",
    "health": {
      "script": "./hooks/health.sh",
      "timeout": 15
    }
  },

  "config": {
    "version": "1.0",
    "properties": {
      "domain": {
        "type": "string",
        "description": "The domain where Core is hosted",
        "env": "DOMAIN"
      },
      "subdomain": {
        "type": "string",
        "description": "The subdomain prefix for the UM resolver (e.g., um for um.peers.social)",
        "default": "um",
        "env": "UM_SUBDOMAIN"
      },
      "dbHost": {
        "type": "string",
        "description": "PostgreSQL host (foundation profile service name)",
        "default": "postgres",
        "env": "UM_DB_HOST"
      },
      "dbPort": {
        "type": "number",
        "description": "PostgreSQL port",
        "default": 5432,
        "env": "UM_DB_PORT"
      },
      "dbName": {
        "type": "string",
        "description": "PostgreSQL database name",
        "default": "universal_manifest",
        "env": "UM_DB_NAME"
      },
      "dbUser": {
        "type": "string",
        "description": "PostgreSQL user",
        "default": "um",
        "env": "UM_DB_USER"
      },
      "dbPassword": {
        "type": "string",
        "description": "PostgreSQL password (prefer file-based secret)",
        "secret": true,
        "env": "UM_DB_PASSWORD"
      },
      "nodeEnv": {
        "type": "string",
        "description": "Node.js environment",
        "default": "production",
        "env": "NODE_ENV",
        "enum": ["development", "production", "test"]
      },
      "port": {
        "type": "number",
        "description": "HTTP server listen port inside container",
        "default": 4200,
        "env": "UM_PORT"
      }
    },
    "required": ["domain"]
  }
}

# ==============================================================
# Social Lab Module - Environment Configuration
# ==============================================================
# Copy this file to .env and customize for your deployment.
#   cp .env.example .env
# ==============================================================

# Required: Domain where Docker Lab is hosted
DOMAIN=core.peermesh.org

# Social Lab subdomain (default: social)
SOCIAL_LAB_SUBDOMAIN=social

# Application port (inside container)
SOCIAL_LAB_PORT=3000

# Database configuration
# Uses the foundation PostgreSQL profile
SOCIAL_LAB_DB_HOST=postgres
SOCIAL_LAB_DB_PORT=5432
SOCIAL_LAB_DB_NAME=social_lab
SOCIAL_LAB_DB_USER=social_lab
# Password is via file-based secret: secrets/social_lab_db_password

# Node.js environment
NODE_ENV=production

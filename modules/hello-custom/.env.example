# ==============================================================
# Hello Custom Module - Environment Configuration
# ==============================================================
# Copy this file to .env and customize for your deployment.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#
# Documentation: hello-custom/README.md
# ==============================================================

# ==============================================================
# Required: Domain
# ==============================================================
# The domain where your Core instance is running.
# The hello custom module will be accessible at hello-custom.${DOMAIN}

# CUSTOMIZE: Set to your actual domain
DOMAIN=example.com

# ==============================================================
# Module Settings
# ==============================================================

# CUSTOMIZE: The greeting message displayed on the page
HELLO_CUSTOM_GREETING=Hello from PeerMesh Custom

# CUSTOMIZE: A short note that appears only in the hello-custom variant
HELLO_CUSTOM_NOTE=Custom variant engaged

# CUSTOMIZE: The subdomain prefix for this module
# The module will be accessible at ${HELLO_CUSTOM_SUBDOMAIN}.${DOMAIN}
HELLO_CUSTOM_SUBDOMAIN=hello-custom

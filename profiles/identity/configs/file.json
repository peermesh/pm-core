      "App:_setups": [
        { "@id": "urn:solid-server:default:Setup" }
      ],
      "App:_cleanupComponents": [
        { "@id": "urn:solid-server:default:CleanupManager" }
      ],
      "App:_finalizers": [
        { "@id": "urn:solid-server:default:Finalizable" }

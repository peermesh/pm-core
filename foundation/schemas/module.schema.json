{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peermesh.io/foundation/v1/module.schema.json",
  "title": "PeerMesh Module Manifest",
  "description": "Schema for module.json manifest files that define PeerMesh modules",
  "type": "object",
  "required": ["id", "version", "name", "foundation"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference",
      "description": "JSON Schema reference for IDE support"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$",
      "minLength": 1,
      "maxLength": 64,
      "description": "Unique module identifier (lowercase alphanumeric with hyphens)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$",
      "description": "Semantic version (e.g., 1.0.0, 1.0.0-alpha.1, 1.0.0+build.123)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Human-readable module name"
    },
    "description": {
      "type": "string",
      "maxLength": 1024,
      "description": "Brief description of module functionality"
    },
    "author": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Author name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Author email"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Author website"
        }
      }
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g., MIT, Apache-2.0)"
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "Git repository URL"
    },
    "foundation": {
      "type": "object",
      "required": ["minVersion"],
      "description": "Foundation version compatibility constraints",
      "properties": {
        "minVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Minimum foundation version required"
        },
        "maxVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Maximum foundation version supported (optional)"
        }
      },
      "additionalProperties": false
    },
    "requires": {
      "type": "object",
      "description": "Module dependencies and connection requirements",
      "properties": {
        "connections": {
          "type": "array",
          "description": "Connection types required by this module",
          "items": {
            "$ref": "#/$defs/connectionRequirement"
          }
        },
        "modules": {
          "type": "array",
          "description": "Other modules this module depends on",
          "items": {
            "$ref": "#/$defs/moduleRequirement"
          }
        },
        "securityServices": {
          "type": "array",
          "description": "Security services this module depends on",
          "items": {
            "type": "string",
            "enum": [
              "identity-provider",
              "key-management",
              "storage-encryption",
              "contract-evaluation",
              "attestation",
              "hardware-abstraction",
              "session-management"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "provides": {
      "type": "object",
      "description": "Capabilities this module provides to the system",
      "properties": {
        "connections": {
          "type": "array",
          "description": "Connection types this module can provide",
          "items": {
            "$ref": "#/$defs/connectionProvider"
          }
        },
        "events": {
          "type": "array",
          "description": "Event types this module may emit",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+\\.[a-z0-9-]+\\.[a-z0-9-]+$",
            "description": "Event type in format: module-id.entity.action"
          }
        },
        "securityServices": {
          "type": "array",
          "description": "Security services this module provides to the system",
          "items": {
            "type": "string",
            "enum": [
              "identity-provider",
              "key-management",
              "storage-encryption",
              "contract-evaluation",
              "contract-enforcement",
              "attestation",
              "hardware-abstraction",
              "session-management",
              "authentication-ux"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "dashboard": {
      "type": "object",
      "description": "Dashboard registration configuration",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "Name shown in dashboard UI"
        },
        "icon": {
          "type": "string",
          "description": "Icon identifier (e.g., 'puzzle', 'database', 'lock')"
        },
        "routes": {
          "type": "array",
          "description": "UI routes to register with dashboard",
          "items": {
            "$ref": "#/$defs/routeRegistration"
          }
        },
        "statusWidget": {
          "$ref": "#/$defs/widgetRegistration",
          "description": "Optional status widget for dashboard overview"
        },
        "configPanel": {
          "$ref": "#/$defs/configPanelRegistration",
          "description": "Optional configuration panel"
        }
      },
      "additionalProperties": false
    },
    "security": {
      "$ref": "security.schema.json",
      "description": "Security requirements and declarations for this module (optional)"
    },
    "lifecycle": {
      "$ref": "lifecycle.schema.json",
      "description": "Lifecycle hook scripts"
    },
    "config": {
      "type": "object",
      "description": "Module configuration schema",
      "properties": {
        "version": {
          "type": "string",
          "description": "Configuration schema version"
        },
        "properties": {
          "type": "object",
          "description": "Configuration property definitions",
          "additionalProperties": {
            "$ref": "#/$defs/configProperty"
          }
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of required configuration properties"
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "description": "Categorization tags for module discovery",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    }
  },
  "$defs": {
    "connectionRequirement": {
      "type": "object",
      "required": ["type", "providers"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["database", "cache", "storage", "queue", "custom"],
          "description": "Connection type category"
        },
        "providers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "Acceptable provider types (e.g., ['postgres', 'mysql', 'sqlite'])"
        },
        "required": {
          "type": "boolean",
          "default": true,
          "description": "Whether this connection is required for module operation"
        },
        "alias": {
          "type": "string",
          "description": "Internal name for this connection (for multiple connections of same type)"
        }
      },
      "additionalProperties": false
    },
    "moduleRequirement": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Required module ID"
        },
        "minVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Minimum version of required module"
        },
        "optional": {
          "type": "boolean",
          "default": false,
          "description": "Whether this dependency is optional"
        }
      },
      "additionalProperties": false
    },
    "connectionProvider": {
      "type": "object",
      "required": ["type", "provider"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["database", "cache", "storage", "queue", "custom"],
          "description": "Connection type this module provides"
        },
        "provider": {
          "type": "string",
          "description": "Provider identifier (e.g., 'postgres', 'redis', 'minio')"
        }
      },
      "additionalProperties": false
    },
    "routeRegistration": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^/[a-z0-9-/]*$",
          "description": "URL path for this route"
        },
        "component": {
          "type": "string",
          "description": "Reference to UI component file"
        },
        "nav": {
          "type": "object",
          "properties": {
            "label": {
              "type": "string",
              "description": "Navigation menu label"
            },
            "icon": {
              "type": "string",
              "description": "Navigation menu icon"
            },
            "order": {
              "type": "integer",
              "description": "Sort order in navigation"
            }
          }
        }
      },
      "additionalProperties": false
    },
    "widgetRegistration": {
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "description": "Reference to widget component file"
        },
        "size": {
          "type": "string",
          "enum": ["small", "medium", "large"],
          "default": "medium",
          "description": "Widget size in dashboard grid"
        },
        "order": {
          "type": "integer",
          "description": "Sort order among widgets"
        }
      },
      "additionalProperties": false
    },
    "configPanelRegistration": {
      "type": "object",
      "properties": {
        "component": {
          "type": "string",
          "description": "Reference to config panel component file"
        }
      },
      "additionalProperties": false
    },
    "configProperty": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "array", "object"],
          "description": "Property data type"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "default": {
          "description": "Default value if not specified"
        },
        "env": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "description": "Environment variable name"
        },
        "secret": {
          "type": "boolean",
          "default": false,
          "description": "Whether this value is sensitive (BYOK pattern)"
        },
        "enum": {
          "type": "array",
          "description": "Allowed values for this property"
        },
        "minimum": {
          "type": "number",
          "description": "Minimum value for number types"
        },
        "maximum": {
          "type": "number",
          "description": "Maximum value for number types"
        },
        "minLength": {
          "type": "integer",
          "description": "Minimum length for string types"
        },
        "maxLength": {
          "type": "integer",
          "description": "Maximum length for string types"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern for string validation"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

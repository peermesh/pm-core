# ==============================================================
# Identity Provider Profile - Environment Variables
# ==============================================================
# Copy relevant variables to your root .env file

# --------------------------------------------------------------
# Required Configuration
# --------------------------------------------------------------

# Your domain (identity server will be at id.${DOMAIN})
# DOMAIN=example.com

# --------------------------------------------------------------
# Optional Configuration
# --------------------------------------------------------------

# Logging level (info, debug, warn, error)
IDENTITY_LOG_LEVEL=info

# Resource limits
IDENTITY_MEMORY_LIMIT=512M
IDENTITY_MEMORY_RESERVATION=256M

# --------------------------------------------------------------
# SMTP Configuration (for password reset emails)
# --------------------------------------------------------------
# Only required if you want email-based password recovery

# Email sender address
# IDENTITY_EMAIL_SENDER=noreply@example.com

# SMTP server settings
# IDENTITY_SMTP_HOST=smtp.example.com
# IDENTITY_SMTP_PORT=587
# IDENTITY_SMTP_USER=smtp-user
# IDENTITY_SMTP_PASSWORD=smtp-password

# --------------------------------------------------------------
# Development Mode (use Mailhog)
# --------------------------------------------------------------
# For local development, use Mailhog as SMTP server:
# IDENTITY_SMTP_HOST=mailhog
# IDENTITY_SMTP_PORT=1025
# (No authentication needed for Mailhog)

# ==============================================================
# rss2bsky Configuration
# ==============================================================
# Copy this to your main .env file and fill in values
# ==============================================================

# Required: Bluesky Handle
# Your full Bluesky handle (e.g., yourname.bsky.social)
RSS2BSKY_HANDLE=yourhandle.bsky.social

# Required: Bluesky App Password
# Generate at: bsky.app -> Settings -> App Passwords
# IMPORTANT: Use an app password, NOT your account password
RSS2BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Required: RSS Feed URL
# GoToSocial: https://social.yourdomain/@username.rss
# Mastodon:   https://mastodon.instance/@username.rss
# WriteFreely: https://blog.yourdomain/feed/
RSS2BSKY_FEED_URL=https://social.example.com/@admin.rss

# Optional: Start Date Filter
# Only crosspost items published after this date
# Use RFC format: "Day, DD Mon YYYY HH:MM:SS +ZZZZ"
# Useful for first deployment to avoid flooding Bluesky with old posts
RSS2BSKY_START_DATE="Tue, 01 Jan 2025 00:00:00 +0000"

# Optional: Cron Schedule
# Default: Every 15 minutes (*/15 * * * *)
# Examples:
#   */5 * * * *   - Every 5 minutes
#   */30 * * * *  - Every 30 minutes
#   0 * * * *     - Every hour
#   0 */6 * * *   - Every 6 hours
RSS2BSKY_CRON=*/15 * * * *

# Security & Credentials (NEVER COMMIT)
*.env
.env.*
!.env.example
!.env.local.example
!.env.staging.example
!.env.production.example
*.key
*.pem
*.p12
*.pfx
credentials.*
secrets.*
*.password
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*

# Secrets directory (keep structure and tooling, ignore actual secrets)
secrets/*
!secrets/.gitkeep
!secrets/README.md
!secrets/justfile
!secrets/.sops.yaml
!secrets/.sops.yaml.example
!secrets/lib/
secrets/lib/*
!secrets/lib/secrets-lib.sh
!secrets/keys/
secrets/keys/*
!secrets/keys/public/
secrets/keys/public/*
!secrets/keys/public/.gitkeep
!secrets/*.enc.yaml
!secrets/*.enc.yaml.example
secrets/*.enc.env
secrets/audit.log

# Backup Files (Auto-added by Smart Commit)
*.backup
*.backup-*
*.bak
*.orig
*~
.*.swp
.*.swo
#*#

# OpenTofu state backups (kept empty in the public tree)
infra/opentofu/state-backups/*
!infra/opentofu/state-backups/README.md

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS Files
.DS_Store
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes
ehthumbs.db

# Editor/IDE
.vscode/
.idea/
*.iml
*.sublime-*
.project
.classpath
.settings/

# Temporary & Cache
*.tmp
*.temp
.cache/
*.pid

# Build Artifacts (if project adds build tooling later)
node_modules/
dist/
build/
__pycache__/
*.pyc
target/

# Nested Git Repositories (should be submodules)
.dev/reference-repos/nself/

# AI artifacts are managed in parent project only
.dev/

# Compiled binaries
services/dashboard/dashboard

# Configuration Files (keep examples, ignore actual configs)
.peermesh.yml
config/targets.yml
!.peermesh.yml.example
!config/targets.yml.example

# ==============================================================
# PeerMesh Core - LOCAL DEVELOPMENT Environment
# ==============================================================
# Copy to .env for local development:
#   ./launch_docker_lab_core.sh env local
#
# Characteristics:
#   - Domain: localhost (no real DNS needed)
#   - TLS: Disabled (HTTP only) or self-signed via mkcert
#   - Logging: DEBUG level for troubleshooting
#   - Profiles: Minimal — only what your module needs
# ==============================================================

# ==============================================================
# REQUIRED CONFIGURATION
# ==============================================================

DOMAIN=localhost
ADMIN_EMAIL=dev@localhost

# ==============================================================
# PROFILE ACTIVATION
# ==============================================================
# Enable only the profiles your module needs for development.
# Example: COMPOSE_PROFILES=postgresql,redis
COMPOSE_PROFILES=

# ==============================================================
# RESOURCE PROFILE
# ==============================================================
# lite: minimal memory footprint for development
RESOURCE_PROFILE=lite

# ==============================================================
# TRAEFIK CONFIGURATION
# ==============================================================

TRAEFIK_LOG_LEVEL=DEBUG
TRAEFIK_WEB_PORT=18000
TRAEFIK_WEBSECURE_PORT=18001
TRAEFIK_MATRIX_FED_PORT=18002
TRAEFIK_DASHBOARD_PORT=18003
TRAEFIK_DASHBOARD_AUTH=

# TLS: Let's Encrypt staging CA (does not issue real certificates,
# does not count against rate limits). For local dev you may also
# disable TLS entirely or use mkcert.
# Leave empty to use production LE (not recommended for local dev).
TRAEFIK_ACME_CASERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# ==============================================================
# CORE DASHBOARD
# ==============================================================

DOCKERLAB_USERNAME=admin
DOCKERLAB_PASSWORD=localdev
DOCKERLAB_DEMO_MODE=true

# ==============================================================
# POSTGRESQL TUNING (when postgresql profile enabled)
# ==============================================================
# Lighter settings for development

POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_EFFECTIVE_CACHE=256MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=32MB
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_MEMORY_LIMIT=512M
POSTGRES_MEMORY_RESERVATION=256M

# ==============================================================
# REDIS TUNING (when redis profile enabled)
# ==============================================================

REDIS_MAXMEMORY=64mb
REDIS_MEMORY_LIMIT=128M
REDIS_MEMORY_RESERVATION=32M
# Redis password is loaded from secrets/redis_password.

# Localhost bindings (reserved for peermesh-core-local-dev in GAS port registry)
MINIO_API_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
PKI_CA_HOST_PORT=19010
MITMPROXY_WEB_HOST_PORT=18081
MITMPROXY_PROXY_HOST_PORT=18082
REDIS_EXPORTER_HOST_PORT=19121

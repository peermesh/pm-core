# Validate all encrypted files and check for plaintext leaks
verify:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    verify_encrypted_files "{{SECRETS_DIR}}"

# List all team members with access
list-members:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    log "Team members with secrets access:"
    echo ""

    if [[ -d "{{SECRETS_DIR}}/keys/public" ]]; then
        for keyfile in "{{SECRETS_DIR}}"/keys/public/*.pub; do
            [[ ! -f "$keyfile" ]] && continue
            name=$(basename "$keyfile" .pub)
            pubkey=$(cat "$keyfile")
            echo "  $name: ${pubkey:0:20}..."
        done
    else
        echo "  No team members configured yet."
    fi

    echo ""

# Show audit log of recent operations
audit limit="20":
    #!/usr/bin/env bash
    set -euo pipefail

    log_file="{{SECRETS_DIR}}/audit.log"

    if [[ ! -f "$log_file" ]]; then
        echo "No audit log found. Operations will be logged after first use."
        exit 0
    fi

    echo ""
    echo "Recent secrets operations (last {{limit}}):"
    echo "============================================"
    echo ""
    echo "Timestamp                  | User           | Command        | Key      | Env"
    echo "---------------------------|----------------|----------------|----------|----"
    tail -n {{limit}} "$log_file" | while IFS='|' read -r ts user cmd key env; do
        printf "%-26s | %-14s | %-14s | %-8s | %s\n" "$ts" "$user" "$cmd" "$key" "$env"
    done
    echo ""

# ============================================================================
# Utility Commands
# ============================================================================

# Show your public key (for sharing with team admin)
show-pubkey:
    #!/usr/bin/env bash
    set -euo pipefail

    key_file="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"
    key_file="${key_file/#\~/$HOME}"

    if [[ ! -f "$key_file" ]]; then
        echo "No age key found at $key_file"
        echo ""
        echo "Generate one with:"
        echo "  mkdir -p ~/.config/sops/age"
        echo "  age-keygen -o ~/.config/sops/age/keys.txt"
        echo "  chmod 600 ~/.config/sops/age/keys.txt"
        exit 1
    fi

    pubkey=$(grep "public key" "$key_file" 2>/dev/null | cut -d: -f2 | tr -d ' ' || echo "")

    if [[ -n "$pubkey" ]]; then
        echo ""
        echo "Your public key (share this with team admin):"
        echo ""
        echo "  $pubkey"
        echo ""
    else
        echo "Could not extract public key from $key_file"
        exit 1
    fi

# Generate a new age keypair
generate-key:
    #!/usr/bin/env bash
    set -euo pipefail

    key_file="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"
    key_file="${key_file/#\~/$HOME}"

    if [[ -f "$key_file" ]]; then
        echo "Key already exists at $key_file"
        echo ""
        echo "Your public key:"
        grep "public key" "$key_file" | cut -d: -f2 | tr -d ' '
        echo ""
        echo "To generate a NEW key, first backup and remove the existing one."
        exit 0
    fi

    mkdir -p "$(dirname "$key_file")"
    age-keygen -o "$key_file"
    chmod 600 "$key_file"

    echo ""
    echo "Key generated at: $key_file"
    echo ""
    echo "Your public key (share this with team admin):"
    grep "public key" "$key_file" | cut -d: -f2 | tr -d ' '
    echo ""
    echo "IMPORTANT: Back up your private key securely!"

# ============================================================================
# Webhook & Deployment Commands
# ============================================================================

# Configuration
DEPLOY_DIR := justfile_directory() + "/../deploy"
DEPLOY_KEYS_DIR := DEPLOY_DIR + "/keys"
WEBHOOK_DIR := DEPLOY_DIR + "/webhook"

# One-command VPS webhook initialization
webhook-setup:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    echo ""
    log "VPS Webhook Setup"
    echo "================="
    echo ""

    # Ensure directories exist
    mkdir -p "{{DEPLOY_KEYS_DIR}}"
    mkdir -p "{{WEBHOOK_DIR}}"

    # Step 1: Generate deploy key if not exists
    deploy_key="{{DEPLOY_KEYS_DIR}}/deploy_key"
    if [[ -f "$deploy_key" ]]; then
        log "Deploy key already exists at $deploy_key"
    else
        log "Generating SSH deploy key (ed25519)..."
        ssh-keygen -t ed25519 -f "$deploy_key" -N "" -C "deploy@$(hostname -s)"
        chmod 600 "$deploy_key"
        chmod 644 "${deploy_key}.pub"
        log "Deploy key generated"
    fi

    # Step 2: Generate webhook secret if not exists
    webhook_env="{{WEBHOOK_DIR}}/webhook.env"
    if [[ -f "$webhook_env" ]]; then
        log "Webhook secret already exists at $webhook_env"
    else
        log "Generating webhook secret..."
        webhook_secret=$(openssl rand -hex 32)
        echo "WEBHOOK_SECRET=${webhook_secret}" > "$webhook_env"
        chmod 600 "$webhook_env"
        log "Webhook secret generated"
    fi

    # Display configuration for GitHub
    echo ""
    echo "=============================================="
    echo "GitHub Configuration"
    echo "=============================================="
    echo ""
    echo -e "${BOLD}1. Add Deploy Key to GitHub:${NC}"
    echo "   Repository -> Settings -> Deploy keys -> Add deploy key"
    echo ""
    echo -e "${YELLOW}Public Key:${NC}"
    cat "${deploy_key}.pub"
    echo ""
    echo -e "${BOLD}2. Configure Webhook in GitHub:${NC}"
    echo "   Repository -> Settings -> Webhooks -> Add webhook"
    echo ""
    echo -e "${YELLOW}Webhook URL:${NC}"
    echo "   https://YOUR_DOMAIN/hooks/deploy"
    echo ""
    echo -e "${YELLOW}Webhook Secret:${NC}"
    grep "WEBHOOK_SECRET" "$webhook_env" | cut -d= -f2
    echo ""
    echo -e "${BOLD}3. Webhook Settings:${NC}"
    echo "   Content type: application/json"
    echo "   Events: Just the push event"
    echo ""
    echo "=============================================="
    echo ""
    log "Next steps:"
    echo "  1. Add the public key to GitHub as a deploy key"
    echo "  2. Configure the webhook in GitHub with the secret above"
    echo "  3. Start the webhook container with: just webhook-start"
    echo ""

    secrets_log "WEBHOOK_SETUP" "initialized" "deploy keys and webhook secret"

# Generate SSH deploy key for GitHub
deploy-key-generate:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    mkdir -p "{{DEPLOY_KEYS_DIR}}"
    deploy_key="{{DEPLOY_KEYS_DIR}}/deploy_key"

    if [[ -f "$deploy_key" ]]; then
        warn "Deploy key already exists at $deploy_key"
        echo ""
        echo "Existing public key:"
        cat "${deploy_key}.pub"
        echo ""
        if ! secrets_confirm "Replace existing deploy key?"; then
            echo "Aborted."
            exit 0
        fi
        rm -f "$deploy_key" "${deploy_key}.pub"
    fi

    log "Generating SSH deploy key (ed25519)..."
    ssh-keygen -t ed25519 -f "$deploy_key" -N "" -C "deploy@$(hostname -s)"
    chmod 600 "$deploy_key"
    chmod 644 "${deploy_key}.pub"

    echo ""
    log "Deploy key generated successfully"
    echo ""
    echo "Key location: $deploy_key"
    echo ""
    echo -e "${BOLD}Add this public key to GitHub:${NC}"
    echo "Repository -> Settings -> Deploy keys -> Add deploy key"
    echo ""
    echo -e "${YELLOW}Public Key:${NC}"
    cat "${deploy_key}.pub"
    echo ""

    secrets_log "DEPLOY_KEY_GENERATE" "ed25519" "{{DEPLOY_KEYS_DIR}}"

# Generate webhook secret for GitHub
webhook-secret-generate:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    mkdir -p "{{WEBHOOK_DIR}}"
    webhook_env="{{WEBHOOK_DIR}}/webhook.env"

    if [[ -f "$webhook_env" ]]; then
        warn "Webhook secret already exists at $webhook_env"
        echo ""
        echo "Current secret:"
        grep "WEBHOOK_SECRET" "$webhook_env" | cut -d= -f2
        echo ""
        if ! secrets_confirm "Generate new webhook secret?"; then
            echo "Aborted."
            exit 0
        fi
    fi

    log "Generating webhook secret (32 bytes, hex encoded)..."
    webhook_secret=$(openssl rand -hex 32)
    echo "WEBHOOK_SECRET=${webhook_secret}" > "$webhook_env"
    chmod 600 "$webhook_env"

    echo ""
    log "Webhook secret generated successfully"
    echo ""
    echo "Secret location: $webhook_env"
    echo ""
    echo -e "${BOLD}Add this secret to GitHub webhook configuration:${NC}"
    echo "Repository -> Settings -> Webhooks -> Edit -> Secret"
    echo ""
    echo -e "${YELLOW}Webhook Secret:${NC}"
    echo "$webhook_secret"
    echo ""
    echo -e "${RED}IMPORTANT: Update the webhook secret in GitHub after regenerating!${NC}"
    echo ""

    secrets_log "WEBHOOK_SECRET_GENERATE" "regenerated" "{{WEBHOOK_DIR}}"

# Check webhook service health and status
webhook-status:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    echo ""
    log "Webhook Service Status"
    echo "======================"
    echo ""

    # Check if webhook container is running
    container_name="webhook"
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${container_name}$"; then
        echo -e "${GREEN}[RUNNING]${NC} Webhook container is active"
        echo ""
        echo "Container details:"
        docker ps --filter "name=${container_name}" --format "  ID: {{.ID}}\n  Image: {{.Image}}\n  Status: {{.Status}}\n  Ports: {{.Ports}}"
    elif docker ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^${container_name}$"; then
        echo -e "${YELLOW}[STOPPED]${NC} Webhook container exists but is not running"
        echo ""
        echo "Container details:"
        docker ps -a --filter "name=${container_name}" --format "  ID: {{.ID}}\n  Image: {{.Image}}\n  Status: {{.Status}}"
        echo ""
        echo "Start with: docker start ${container_name}"
    else
        echo -e "${YELLOW}[NOT FOUND]${NC} No webhook container found"
        echo ""
        echo "Start webhook with: just webhook-start"
    fi

    echo ""

    # Check configuration files
    log "Configuration Files:"
    echo ""
    deploy_key="{{DEPLOY_KEYS_DIR}}/deploy_key"
    webhook_env="{{WEBHOOK_DIR}}/webhook.env"

    if [[ -f "$deploy_key" ]]; then
        echo -e "  ${GREEN}[OK]${NC} Deploy key: $deploy_key"
    else
        echo -e "  ${RED}[MISSING]${NC} Deploy key: $deploy_key"
    fi

    if [[ -f "${deploy_key}.pub" ]]; then
        echo -e "  ${GREEN}[OK]${NC} Deploy key (public): ${deploy_key}.pub"
    else
        echo -e "  ${RED}[MISSING]${NC} Deploy key (public): ${deploy_key}.pub"
    fi

    if [[ -f "$webhook_env" ]]; then
        echo -e "  ${GREEN}[OK]${NC} Webhook secret: $webhook_env"
    else
        echo -e "  ${RED}[MISSING]${NC} Webhook secret: $webhook_env"
    fi

    echo ""

    # Show recent logs if container exists
    if docker ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^${container_name}$"; then
        log "Recent Logs (last 10 lines):"
        echo ""
        docker logs --tail 10 "${container_name}" 2>&1 | sed 's/^/  /'
        echo ""
    fi

    # Test endpoint if running
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${container_name}$"; then
        log "Endpoint Test:"
        echo ""
        # Try to get the port mapping
        port=$(docker port "${container_name}" 2>/dev/null | grep -oE '[0-9]+$' | head -1 || echo "9000")
        if curl -s -o /dev/null -w "%{http_code}" "http://localhost:${port}/health" 2>/dev/null | grep -qE "^(200|404)$"; then
            echo -e "  ${GREEN}[OK]${NC} Webhook endpoint is accessible on port ${port}"
        else
            echo -e "  ${YELLOW}[WARN]${NC} Could not reach webhook endpoint on port ${port}"
        fi
        echo ""
    fi

# View webhook container logs
webhook-logs *args='':
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    container_name="webhook"

    # Check if container exists
    if ! docker ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^${container_name}$"; then
        error "Webhook container not found"
        echo ""
        echo "Start webhook with: just webhook-start"
        exit 1
    fi

    # Default to follow mode with tail
    args="{{args}}"
    if [[ -z "$args" ]]; then
        args="--follow --tail 100"
    fi

    log "Viewing webhook logs (Ctrl+C to exit)..."
    echo ""
    docker logs $args "${container_name}"

# Start the webhook container
webhook-start:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    # Check prerequisites
    deploy_key="{{DEPLOY_KEYS_DIR}}/deploy_key"
    webhook_env="{{WEBHOOK_DIR}}/webhook.env"

    if [[ ! -f "$deploy_key" ]]; then
        error "Deploy key not found: $deploy_key"
        echo "Generate with: just deploy-key-generate"
        exit 1
    fi

    if [[ ! -f "$webhook_env" ]]; then
        error "Webhook secret not found: $webhook_env"
        echo "Generate with: just webhook-secret-generate"
        exit 1
    fi

    log "Starting webhook container..."

    # Check if container already exists
    container_name="webhook"
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${container_name}$"; then
        warn "Webhook container is already running"
        exit 0
    fi

    if docker ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^${container_name}$"; then
        log "Starting existing container..."
        docker start "${container_name}"
    else
        log "Creating and starting webhook container..."
        # Placeholder - actual docker run command depends on webhook image
        echo ""
        warn "No default webhook image configured."
        echo ""
        echo "To start the webhook service, use docker compose or docker run with your webhook image."
        echo ""
        echo "Example with webhook (https://github.com/adnanh/webhook):"
        echo "  docker run -d --name webhook \\"
        echo "    -p 9000:9000 \\"
        echo "    -v {{DEPLOY_KEYS_DIR}}:/keys:ro \\"
        echo "    -v {{WEBHOOK_DIR}}:/config:ro \\"
        echo "    --env-file {{WEBHOOK_DIR}}/webhook.env \\"
        echo "    almir/webhook -verbose -hooks /config/hooks.json"
        echo ""
        exit 0
    fi

    log "Webhook container started"
    secrets_log "WEBHOOK_START" "container" "${container_name}"

# Stop the webhook container
webhook-stop:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    container_name="webhook"

    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${container_name}$"; then
        warn "Webhook container is not running"
        exit 0
    fi

    log "Stopping webhook container..."
    docker stop "${container_name}"
    log "Webhook container stopped"
    secrets_log "WEBHOOK_STOP" "container" "${container_name}"

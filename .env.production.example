# ==============================================================
# PeerMesh Core - PRODUCTION Environment
# ==============================================================
# Copy to .env for production deployment:
#   ./launch_docker_lab_core.sh env production
#
# Characteristics:
#   - Domain: peers.social (or your production domain)
#   - TLS: Let's Encrypt production (real, trusted certificates)
#   - Logging: WARN level (minimal noise)
#   - Profiles: Only production-validated services
#
# IMPORTANT: Review ALL values before deploying.
#   - Set strong password for DOCKERLAB_PASSWORD
#   - Set TRAEFIK_DASHBOARD_AUTH
#   - Run ./scripts/generate-secrets.sh
# ==============================================================

# ==============================================================
# REQUIRED CONFIGURATION
# ==============================================================

DOMAIN=peers.social
ADMIN_EMAIL=admin@peers.social

# ==============================================================
# PROFILE ACTIVATION
# ==============================================================
# Production: only validated, necessary profiles.
COMPOSE_PROFILES=postgresql,redis

# ==============================================================
# RESOURCE PROFILE
# ==============================================================
# core or full depending on VPS sizing
RESOURCE_PROFILE=core

# ==============================================================
# TRAEFIK CONFIGURATION
# ==============================================================

TRAEFIK_LOG_LEVEL=WARN
TRAEFIK_WEB_PORT=80
TRAEFIK_WEBSECURE_PORT=443
TRAEFIK_MATRIX_FED_PORT=8448
TRAEFIK_DASHBOARD_PORT=8080

# REQUIRED: Generate with: htpasswd -nb admin your_secure_password
TRAEFIK_DASHBOARD_AUTH=

# TLS: Production Let's Encrypt (default).
# Leave empty or remove — Traefik defaults to production LE.
TRAEFIK_ACME_CASERVER=

# ==============================================================
# CORE DASHBOARD
# ==============================================================

DOCKERLAB_USERNAME=admin
# REQUIRED: Generate with: openssl rand -base64 24
DOCKERLAB_PASSWORD=
DOCKERLAB_DEMO_MODE=false

# ==============================================================
# POSTGRESQL TUNING (when postgresql profile enabled)
# ==============================================================

POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE=768MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_MEMORY_LIMIT=1G
POSTGRES_MEMORY_RESERVATION=512M

# ==============================================================
# REDIS TUNING (when redis profile enabled)
# ==============================================================

REDIS_MAXMEMORY=128mb
REDIS_MEMORY_LIMIT=256M
REDIS_MEMORY_RESERVATION=64M

# Redis password is loaded from secrets/redis_password.

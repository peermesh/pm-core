# ==============================================================
# Peer Mesh Docker Lab - Environment Configuration
# ==============================================================
# Copy this file to .env and customize values.
# Run ./scripts/generate-secrets.sh before first start.
# ==============================================================

# ==============================================================
# REQUIRED CONFIGURATION
# ==============================================================

# Domain for your services (e.g., example.com)
# Services will be available at subdomains: app.example.com, db.example.com
DOMAIN=example.com

# Email for Let's Encrypt certificate registration
# You will receive expiry notices at this address
ADMIN_EMAIL=admin@example.com

# ==============================================================
# PROFILE ACTIVATION
# ==============================================================
# Comma-separated list of profiles to enable.
#
# SUPPORTING TECH PROFILES (select what your app needs):
#   postgresql  - PostgreSQL 16 with pgvector
#   mysql       - MySQL 8.0
#   mongodb     - MongoDB 6.0
#   redis       - Redis 7 / Valkey
#   minio       - S3-compatible object storage
#
# FEATURE PROFILES (optional add-ons):
#   monitoring  - Prometheus, Grafana, Loki (adds ~500MB RAM)
#   backup      - Automated backup container (adds ~50MB RAM)
#   dev         - Adminer, Mailhog, debug tools (adds ~100MB RAM)
#
# Example: COMPOSE_PROFILES=postgresql,redis,backup
COMPOSE_PROFILES=

# ==============================================================
# RESOURCE PROFILE
# ==============================================================
# Determines base memory allocations. Override individual limits below.
#
# lite: ~1GB VPS, minimal services
# core: ~4GB VPS, standard deployment
# full: ~8GB+ VPS, everything + observability
RESOURCE_PROFILE=core

# ==============================================================
# TRAEFIK CONFIGURATION
# ==============================================================

# Log level: DEBUG, INFO, WARN, ERROR
TRAEFIK_LOG_LEVEL=INFO

# Dashboard port (localhost only) - change if 8080 is in use
TRAEFIK_DASHBOARD_PORT=8080

# Traefik dashboard authentication (optional - leave empty to disable remote access)
# Generate with: htpasswd -nb admin your_secure_password
# Example: admin:$apr1$...
TRAEFIK_DASHBOARD_AUTH=

# ==============================================================
# DASHBOARD CONFIGURATION (REQUIRED FOR PUBLIC ACCESS)
# ==============================================================
# The main dashboard at ${DOMAIN} requires authentication.
# This is auto-generated by ./scripts/generate-secrets.sh
#
# To manually generate:
#   htpasswd -nbB admin "$(openssl rand -base64 24)"
#
# SECURITY NOTES:
# - Uses bcrypt hashing (more secure than apr1/md5)
# - Rate limited to 10 requests/minute per IP
# - Security headers: HSTS, X-Frame-Options, XSS protection
# - Not indexed by search engines (X-Robots-Tag: noindex)
#
# Format: username:$2y$... (bcrypt hash)
DASHBOARD_AUTH=

# ==============================================================
# POSTGRESQL TUNING (when postgresql profile enabled)
# ==============================================================
# Use D10 Resource Calculator to size these appropriately

POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE=768MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_MEMORY_LIMIT=1G
POSTGRES_MEMORY_RESERVATION=512M

# ==============================================================
# MYSQL TUNING (when mysql profile enabled)
# ==============================================================

MYSQL_BUFFER_POOL_SIZE=256M
MYSQL_MAX_CONNECTIONS=100
MYSQL_MEMORY_LIMIT=1G
MYSQL_MEMORY_RESERVATION=512M

# ==============================================================
# MONGODB TUNING (when mongodb profile enabled)
# ==============================================================

MONGODB_CACHE_SIZE_GB=0.25
MONGODB_MEMORY_LIMIT=1G
MONGODB_MEMORY_RESERVATION=512M

# ==============================================================
# REDIS TUNING (when redis profile enabled)
# ==============================================================

REDIS_MAXMEMORY=128mb
REDIS_MEMORY_LIMIT=256M
REDIS_MEMORY_RESERVATION=64M

# ==============================================================
# MINIO TUNING (when minio profile enabled)
# ==============================================================

MINIO_MEMORY_LIMIT=512M
MINIO_MEMORY_RESERVATION=128M

# ==============================================================
# MULTI-DOMAIN SUPPORT
# ==============================================================
# For hosting multiple domains on the same VPS.
# Each domain uses compose override files: docker-compose.{domain}.yml
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.dc.yml up -d
#   Or set COMPOSE_FILE=docker-compose.yml:docker-compose.dc.yml

# Additional domains (uncomment as needed)
# DC_DOMAIN=distributedcreators.org
# PM_DOMAIN=peermesh.org

# ==============================================================
# SERVICE URL CONFIGURATION
# ==============================================================
# Full URLs for services that require them (include https://)
# These MUST match your Traefik host rules

# Ghost CMS (required if ghost profile enabled)
# GHOST_URL=https://ghost.${DOMAIN}

# PeerTube (required if peertube enabled)
# PEERTUBE_HOSTNAME=peertube.${DOMAIN}

# Synapse Matrix Server
# SYNAPSE_SERVER_NAME=matrix.${DOMAIN}

# Solid Community Server
# SOLID_BASE_URL=https://solid.${DOMAIN}

# ==============================================================
# Mastodon Module - Environment Configuration
# ==============================================================
# Copy this file to .env and configure for your instance
#
# Required variables are marked with (REQUIRED)
# Optional variables have sensible defaults
#
# Generate secrets: ./hooks/install.sh
# Then source: configs/mastodon_secrets.env
# ==============================================================

# --------------------------------------------------------------
# Instance Configuration (REQUIRED)
# --------------------------------------------------------------

# Your instance domain - must be publicly accessible
# This CANNOT be changed after instance creation
MASTODON_LOCAL_DOMAIN=mastodon.example.com

# Single user mode (set to true for personal instance)
# Disables registrations and hides timeline tabs
MASTODON_SINGLE_USER_MODE=false

# Instance branding
MASTODON_SITE_TITLE=My Mastodon Instance
MASTODON_SITE_DESCRIPTION=A federated social network powered by PeerMesh

# Admin contact email (REQUIRED)
MASTODON_ADMIN_EMAIL=admin@example.com

# Registrations mode: open, approval_required, none
MASTODON_REGISTRATIONS_MODE=approval_required

# Maximum post length (default: 500)
MASTODON_MAX_TOOT_CHARS=500

# --------------------------------------------------------------
# Security Keys (REQUIRED - auto-generated by install.sh)
# --------------------------------------------------------------
# Source from: configs/mastodon_secrets.env
# Or set directly here (not recommended for production)

# Rails secret key base (64 hex characters)
MASTODON_SECRET_KEY_BASE=

# OTP secret for 2FA (64 hex characters)
MASTODON_OTP_SECRET=

# VAPID keys for web push notifications
# Generate with: docker compose run --rm mastodon-web bundle exec rake mastodon:webpush:generate_vapid_key
MASTODON_VAPID_PRIVATE_KEY=
MASTODON_VAPID_PUBLIC_KEY=

# --------------------------------------------------------------
# Database Configuration
# --------------------------------------------------------------
# Defaults connect to pmdl_postgres container
# Database is auto-created by install.sh

MASTODON_DB_HOST=postgres
MASTODON_DB_PORT=5432
MASTODON_DB_NAME=mastodon
MASTODON_DB_USER=mastodon

# Password from secrets/mastodon_db_password (auto-generated)
MASTODON_DB_PASSWORD=

# --------------------------------------------------------------
# Redis Configuration
# --------------------------------------------------------------
# Defaults connect to pmdl_redis container

MASTODON_REDIS_HOST=redis
MASTODON_REDIS_PORT=6379
MASTODON_REDIS_PASSWORD=

# --------------------------------------------------------------
# OpenSearch Configuration (Full-text Search)
# --------------------------------------------------------------
# OpenSearch runs as part of this module

MASTODON_ES_ENABLED=true
MASTODON_ES_HOST=opensearch
MASTODON_ES_PORT=9200

# --------------------------------------------------------------
# Email Configuration (Optional but recommended)
# --------------------------------------------------------------
# Required for: password resets, email confirmations, notifications

# SMTP server settings
MASTODON_SMTP_SERVER=
MASTODON_SMTP_PORT=587
MASTODON_SMTP_LOGIN=
MASTODON_SMTP_PASSWORD=

# From address for outgoing emails
MASTODON_SMTP_FROM_ADDRESS=notifications@${MASTODON_LOCAL_DOMAIN}

# Authentication method: plain, login, cram_md5
MASTODON_SMTP_AUTH_METHOD=plain

# TLS settings: always, never, auto
MASTODON_SMTP_ENABLE_STARTTLS=auto

# SSL verification: none, peer
MASTODON_SMTP_OPENSSL_VERIFY_MODE=peer

# --------------------------------------------------------------
# S3-Compatible Storage (Optional)
# --------------------------------------------------------------
# For production, use S3/MinIO for media storage
# Leave S3_ENABLED=false to use local storage

MASTODON_S3_ENABLED=false
MASTODON_S3_BUCKET=
MASTODON_S3_REGION=us-east-1

# For MinIO or other S3-compatible services
MASTODON_S3_ENDPOINT=
MASTODON_S3_ACCESS_KEY=
MASTODON_S3_SECRET_KEY=

# Public hostname for S3 bucket (for CDN/proxy)
MASTODON_S3_HOSTNAME=

# --------------------------------------------------------------
# Performance Tuning
# --------------------------------------------------------------

# Puma web workers (more = more memory, better concurrency)
# Recommended: 2 per CPU core
MASTODON_WEB_CONCURRENCY=2

# Threads per Puma worker
MASTODON_MAX_THREADS=5

# Streaming server workers
MASTODON_STREAMING_CLUSTER_NUM=1

# Sidekiq worker threads (background jobs)
# Higher = faster federation/email but more DB connections
MASTODON_SIDEKIQ_CONCURRENCY=25

# Log level: debug, info, warn, error
MASTODON_LOG_LEVEL=warn

# --------------------------------------------------------------
# Federation Settings
# --------------------------------------------------------------

# Require signed fetch (enhanced privacy, may break some clients)
MASTODON_AUTHORIZED_FETCH=true

# Limited federation mode (allowlist-only federation)
# Requires manual approval of each remote instance
MASTODON_LIMITED_FEDERATION_MODE=false

# --------------------------------------------------------------
# Advanced Settings
# --------------------------------------------------------------

# Disable IP-based rate limiting (use if behind proxy)
# MASTODON_DISABLE_IP_RATE_LIMITING=false

# Trusted proxy IPs (for X-Forwarded-For header)
# MASTODON_TRUSTED_PROXY_IPS=172.16.0.0/12

# Hide user networks (followers/following lists)
# MASTODON_HIDE_NETWORKS=false

# Enable Keybase integration
# MASTODON_KEYBASE_INTEGRATION=false

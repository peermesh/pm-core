# ==============================================================
# Backup Module Configuration
# ==============================================================
# Copy this file to .env and customize for your deployment.
#
# Required secrets are stored in configs/ directory:
#   - configs/restic_password (required for encryption)
#   - configs/s3_access_key (optional, for off-site backup)
#   - configs/s3_secret_key (optional, for off-site backup)
#
# Documentation: modules/backup/README.md
# Decision Reference: docs/decisions/0102-backup-architecture.md
# ==============================================================

# ==============================================================
# Storage Paths
# ==============================================================

# Local backup directory
# This directory stores all backup files (PostgreSQL dumps, volume archives)
BACKUP_LOCAL_PATH=/var/backups/pmdl

# Docker volume prefix filter
# Only volumes matching this prefix will be backed up
VOLUME_PREFIX=pmdl_

# ==============================================================
# Target Containers
# ==============================================================

# PostgreSQL container name to backup
POSTGRES_CONTAINER_NAME=pmdl_postgres

# ==============================================================
# Backup Schedule (Cron Format)
# ==============================================================
# Format: minute hour day-of-month month day-of-week
# Examples:
#   0 2 * * *     = 2:00 AM daily
#   0 */6 * * *   = Every 6 hours
#   0 2 * * 0     = 2:00 AM on Sundays only

# PostgreSQL backup schedule (default: 2:00 AM daily)
BACKUP_SCHEDULE_POSTGRES=0 2 * * *

# Volume backup schedule (default: 3:00 AM daily)
BACKUP_SCHEDULE_VOLUMES=0 3 * * *

# Off-site sync schedule (default: 4:00 AM daily)
BACKUP_SCHEDULE_OFFSITE=0 4 * * *

# Retention cleanup schedule (default: 5:00 AM daily)
BACKUP_SCHEDULE_RETENTION=0 5 * * *

# ==============================================================
# Retention Policy
# ==============================================================
# How long to keep backups in each tier

# Daily backups to keep (default: 7 days)
BACKUP_RETENTION_DAILY=7

# Weekly backups to keep (default: 4 weeks)
BACKUP_RETENTION_WEEKLY=4

# Monthly backups to keep (default: 3 months)
BACKUP_RETENTION_MONTHLY=3

# ==============================================================
# Restic Repository (Optional)
# ==============================================================
# Use restic for deduplication and encryption
# Leave empty to use simple tar.gz backups

# Restic repository location
# Examples:
#   /var/backups/pmdl/restic                        (local)
#   s3:s3.amazonaws.com/bucket-name/path            (AWS S3)
#   s3:https://minio.example.com/bucket/path        (MinIO)
#   sftp:user@host:/path                            (SFTP)
BACKUP_RESTIC_REPOSITORY=

# Note: Password is read from configs/restic_password file

# ==============================================================
# S3/MinIO Off-site Storage (Optional)
# ==============================================================
# Configure for off-site backup sync

# S3-compatible endpoint URL
# Examples:
#   https://s3.amazonaws.com                        (AWS S3)
#   https://s3.us-west-1.amazonaws.com              (AWS regional)
#   https://minio.example.com                       (Self-hosted MinIO)
#   https://s3.wasabisys.com                        (Wasabi)
#   https://s3.us-west-004.backblazeb2.com          (Backblaze B2)
BACKUP_S3_ENDPOINT=

# S3 bucket name
BACKUP_S3_BUCKET=

# Bandwidth limit for off-site sync (KB/s, 0 = unlimited)
BACKUP_BANDWIDTH_LIMIT=0

# Note: Credentials are read from configs/s3_access_key and configs/s3_secret_key files

# ==============================================================
# Encryption (Optional)
# ==============================================================
# Additional encryption for backups using age

# Age public key for encryption (starts with age1...)
# Generate with: age-keygen -o key.txt
# The public key is printed when generating
BACKUP_AGE_RECIPIENT=

# ==============================================================
# Advanced Options
# ==============================================================

# Pre-backup hook script (runs before each backup)
# PRE_BACKUP_HOOK=/path/to/script.sh

# Post-backup hook script (runs after successful backup)
# POST_BACKUP_HOOK=/path/to/script.sh

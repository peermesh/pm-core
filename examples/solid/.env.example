# ==============================================================
# Solid Community Server Environment Configuration
# ==============================================================
# Copy this file to .env and configure for your deployment
#
# Usage:
#   cp .env.example .env
#   nano .env
# ==============================================================

# ==============================================================
# Required Configuration
# ==============================================================

# Your domain (used by Traefik for routing)
DOMAIN=example.com

# ==============================================================
# Optional Configuration
# ==============================================================

# Solid Community Server uses CSS_BASE_URL derived from DOMAIN.
# The base URL will be: https://solid.${DOMAIN}/

# For advanced configuration, you can mount a custom config file.
# See: https://communitysolidserver.github.io/CommunitySolidServer/

# ==============================================================
# Notes
# ==============================================================
# Solid Community Server does not require database secrets for
# basic file-based storage configuration.
#
# User registration and pod creation is handled through the
# web interface at https://solid.${DOMAIN}/
#
# For production deployments with external OIDC providers,
# additional configuration may be needed.
# ==============================================================

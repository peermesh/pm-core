# ==============================================================
# Hello Core Module - Environment Configuration
# ==============================================================
# Copy this file to .env and customize for your deployment.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#
# Documentation: hello-core/README.md
# ==============================================================

# ==============================================================
# Required: Domain
# ==============================================================
# The domain where your Core instance is running.
# The Hello Core Module will be accessible at hello-core.${DOMAIN}

# CUSTOMIZE: Set to your actual domain
DOMAIN=example.com

# ==============================================================
# Module Settings
# ==============================================================

# CUSTOMIZE: The greeting message displayed on the page
HELLO_CORE_GREETING=Hello from PeerMesh!

# CUSTOMIZE: The subdomain prefix for this module
# The module will be accessible at ${HELLO_CORE_SUBDOMAIN}.${DOMAIN}
HELLO_CORE_SUBDOMAIN=hello-core

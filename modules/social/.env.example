# ==============================================================
# Social Module - Environment Configuration
# ==============================================================
# Copy this file to .env and customize for your deployment.
#   cp .env.example .env
# ==============================================================

# Required: Set to your deployment domain
# Staging: DOMAIN=dockerlab.peermesh.org
# Production: DOMAIN=peers.social
DOMAIN=peers.social

# Social subdomain prefix.
# Leave empty for root domain deployment (e.g. peers.social).
# Set to "social" for subdomain deployment (e.g. social.dockerlab.peermesh.org).
SOCIAL_LAB_SUBDOMAIN=

# Application port (inside container)
SOCIAL_LAB_PORT=3000

# When 1/true/yes: return 403 for selected experimental stub JSON routes
# (DSNP profile, Hypercore feed, Braid version). Default unset = stubs stay on (backward compatible).
# SOCIAL_LAB_RESTRICT_EXPERIMENTAL_STUBS=

# Database configuration
# Uses the foundation PostgreSQL profile
SOCIAL_LAB_DB_HOST=postgres
SOCIAL_LAB_DB_PORT=5432
SOCIAL_LAB_DB_NAME=social_lab
SOCIAL_LAB_DB_USER=social_lab
# Password is via file-based secret: secrets/social_lab_db_password

# Node.js environment
NODE_ENV=production

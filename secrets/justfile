# secrets/justfile
# Secrets management wrapper for SOPS + age
#
# Usage: just <command> [args]
# Run 'just' or 'just help' to see available commands.
#
# This justfile provides a developer-friendly interface to SOPS+age
# for encrypted secrets management. All operations use process
# substitution to avoid leaving plaintext secrets on disk.

set dotenv-load := false
set shell := ["bash", "-euo", "pipefail", "-c"]

# Configuration
SECRETS_DIR := justfile_directory()
DEFAULT_ENV := "production"
SOPS_AGE_KEY_FILE := env_var_or_default("SOPS_AGE_KEY_FILE", "~/.config/sops/age/keys.txt")

# ============================================================================
# Help & Discovery
# ============================================================================

# Show available commands (default)
default:
    @echo ""
    @echo "Secrets Management Commands"
    @echo "==========================="
    @echo ""
    @echo "Setup & Info:"
    @echo "  just init                     First-time setup, check dependencies"
    @echo "  just help                     This help message"
    @echo "  just verify                   Validate all encrypted files"
    @echo ""
    @echo "Daily Operations:"
    @echo "  just add KEY VALUE [ENV]      Add a secret (default: production)"
    @echo "  just edit [ENV]               Edit secrets in \$EDITOR"
    @echo "  just view [ENV]               View secrets (masked, terminal only)"
    @echo "  just view ENV --reveal        View secrets with full values"
    @echo "  just rotate KEY [ENV]         Rotate a credential with checklist"
    @echo ""
    @echo "Team Management:"
    @echo "  just member-add NAME PUBKEY   Add team member's public key"
    @echo "  just member-remove NAME       Remove member (with rotation reminder)"
    @echo ""
    @echo "Deployment:"
    @echo "  just deploy [ENV]             Decrypt for docker compose"
    @echo ""
    @echo "Environments: production (default), staging, development"
    @echo ""

# Alias for default
help: default

# ============================================================================
# Setup & Initialization
# ============================================================================

# First-time setup: check dependencies, create .sops.yaml if missing
init:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    echo ""
    check_dependencies
    echo ""
    check_age_key
    echo ""

    # Create .sops.yaml if missing
    if [[ ! -f "{{SECRETS_DIR}}/.sops.yaml" ]]; then
        create_sops_config "{{SECRETS_DIR}}"
        echo ""
    else
        log ".sops.yaml already exists"
    fi

    # Create directories
    mkdir -p "{{SECRETS_DIR}}/keys/public"
    mkdir -p "{{SECRETS_DIR}}/lib"

    # Test decryption if files exist
    test_decryption "{{SECRETS_DIR}}"

    echo ""
    log "Setup complete. Run 'just help' for available commands."

# ============================================================================
# Secret Operations
# ============================================================================

# Add a new secret (default environment: production)
add key value env=DEFAULT_ENV:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    validate_env "{{env}}"
    validate_key_name "{{key}}"

    file="{{SECRETS_DIR}}/{{env}}.enc.yaml"

    # Create file if it doesn't exist
    if [[ ! -f "$file" ]]; then
        warn "Secrets file does not exist: {{env}}.enc.yaml"
        if confirm "Create new encrypted file for {{env}}?"; then
            ensure_secrets_file "$file" "{{env}}"
        else
            echo "Aborted."
            exit 0
        fi
    fi

    add_secret "$file" "{{key}}" "{{value}}"
    log_operation "add" "{{key}}" "{{env}}"

# Edit secrets in $EDITOR
edit env=DEFAULT_ENV:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    validate_env "{{env}}"
    file="{{SECRETS_DIR}}/{{env}}.enc.yaml"

    if [[ ! -f "$file" ]]; then
        error "Secrets file not found: $file"
        echo "Create it first with: just add KEY VALUE {{env}}"
        exit 1
    fi

    # Determine editor
    if [[ -n "${EDITOR:-}" ]]; then
        editor="$EDITOR"
    elif command -v code &> /dev/null; then
        editor="code --wait"
    elif command -v vim &> /dev/null; then
        editor="vim"
    elif command -v nano &> /dev/null; then
        editor="nano"
    else
        error "No editor found. Set \$EDITOR environment variable."
        exit 1
    fi

    log "Opening {{env}}.enc.yaml in $editor..."
    log_operation "edit" "-" "{{env}}"

    # SOPS handles decryption/encryption transparently
    EDITOR="$editor" sops "$file"

    log "Saved and encrypted."

# View secrets (terminal only, masked by default)
view env=DEFAULT_ENV *flags='':
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    # Safety: prevent piping to file
    if [[ ! -t 1 ]]; then
        echo ""
        error "SECURITY: Cannot pipe secrets to file or other command."
        echo "Secrets must be viewed in terminal only."
        echo ""
        exit 1
    fi

    validate_env "{{env}}"
    file="{{SECRETS_DIR}}/{{env}}.enc.yaml"

    if [[ ! -f "$file" ]]; then
        error "Secrets file not found: $file"
        exit 1
    fi

    log_operation "view" "-" "{{env}}"

    # Check for --reveal flag
    reveal="false"
    for flag in {{flags}}; do
        if [[ "$flag" == "--reveal" ]]; then
            reveal="true"
        fi
    done

    view_secrets "$file" "$reveal"

# Rotate a specific secret with checklist
rotate key env=DEFAULT_ENV:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    validate_env "{{env}}"
    validate_key_name "{{key}}"
    file="{{SECRETS_DIR}}/{{env}}.enc.yaml"

    rotate_secret "$file" "{{key}}"
    log_operation "rotate" "{{key}}" "{{env}}"

# ============================================================================
# Team Member Management
# ============================================================================

# Add a new team member's public key
member-add name pubkey:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    validate_pubkey "{{pubkey}}"
    add_member "{{SECRETS_DIR}}" "{{name}}" "{{pubkey}}"
    log_operation "member-add" "{{name}}" "-"

# Remove a team member (with rotation reminder)
member-remove name:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    remove_member "{{SECRETS_DIR}}" "{{name}}"
    log_operation "member-remove" "{{name}}" "-"
    show_rotation_reminder "{{name}}"

# ============================================================================
# Deployment
# ============================================================================

# Decrypt secrets and run docker compose (uses process substitution)
deploy env=DEFAULT_ENV:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    validate_env "{{env}}"
    file="{{SECRETS_DIR}}/{{env}}.enc.yaml"

    if [[ ! -f "$file" ]]; then
        error "Secrets file not found: $file"
        exit 1
    fi

    log "Deploying with {{env}} secrets..."
    log_operation "deploy" "-" "{{env}}"

    # Change to project root (parent of secrets dir)
    cd "{{SECRETS_DIR}}/.."

    # Use process substitution - secrets never touch disk
    # Convert YAML to env format for docker compose
    docker compose --env-file <(sops -d "$file" | grep -v '^#' | grep ':' | sed 's/: /=/') up -d

    log "Deployment complete."

# Deploy with specific compose file
deploy-compose env=DEFAULT_ENV compose_file="docker-compose.yml":
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    validate_env "{{env}}"
    file="{{SECRETS_DIR}}/{{env}}.enc.yaml"

    if [[ ! -f "$file" ]]; then
        error "Secrets file not found: $file"
        exit 1
    fi

    log "Deploying with {{env}} secrets using {{compose_file}}..."
    log_operation "deploy-compose" "-" "{{env}}"

    cd "{{SECRETS_DIR}}/.."

    docker compose -f "{{compose_file}}" --env-file <(sops -d "$file" | grep -v '^#' | grep ':' | sed 's/: /=/') up -d

    log "Deployment complete."

# Export secrets as environment variables (for scripts)
export-env env=DEFAULT_ENV:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    # Safety: only allow in terminal
    if [[ ! -t 1 ]]; then
        error "SECURITY: Cannot pipe secrets. Use: eval \$(just export-env {{env}})"
        exit 1
    fi

    validate_env "{{env}}"
    file="{{SECRETS_DIR}}/{{env}}.enc.yaml"

    if [[ ! -f "$file" ]]; then
        error "Secrets file not found: $file"
        exit 1
    fi

    log_operation "export-env" "-" "{{env}}"

    echo "# Source these with: eval \$(just export-env {{env}})"
    sops -d "$file" 2>/dev/null | grep -v '^#' | grep ':' | while IFS=: read -r key value; do
        value=$(echo "$value" | xargs 2>/dev/null || echo "$value")
        echo "export $key=\"$value\""
    done

# ============================================================================
# Verification & Maintenance
# ============================================================================

# Validate all encrypted files and check for plaintext leaks
verify:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    verify_encrypted_files "{{SECRETS_DIR}}"

# List all team members with access
list-members:
    #!/usr/bin/env bash
    set -euo pipefail
    source "{{SECRETS_DIR}}/lib/secrets-lib.sh"
    export SECRETS_DIR="{{SECRETS_DIR}}"

    log "Team members with secrets access:"
    echo ""

    if [[ -d "{{SECRETS_DIR}}/keys/public" ]]; then
        for keyfile in "{{SECRETS_DIR}}"/keys/public/*.pub; do
            [[ ! -f "$keyfile" ]] && continue
            name=$(basename "$keyfile" .pub)
            pubkey=$(cat "$keyfile")
            echo "  $name: ${pubkey:0:20}..."
        done
    else
        echo "  No team members configured yet."
    fi

    echo ""

# Show audit log of recent operations
audit limit="20":
    #!/usr/bin/env bash
    set -euo pipefail

    log_file="{{SECRETS_DIR}}/audit.log"

    if [[ ! -f "$log_file" ]]; then
        echo "No audit log found. Operations will be logged after first use."
        exit 0
    fi

    echo ""
    echo "Recent secrets operations (last {{limit}}):"
    echo "============================================"
    echo ""
    echo "Timestamp                  | User           | Command        | Key      | Env"
    echo "---------------------------|----------------|----------------|----------|----"
    tail -n {{limit}} "$log_file" | while IFS='|' read -r ts user cmd key env; do
        printf "%-26s | %-14s | %-14s | %-8s | %s\n" "$ts" "$user" "$cmd" "$key" "$env"
    done
    echo ""

# ============================================================================
# Utility Commands
# ============================================================================

# Show your public key (for sharing with team admin)
show-pubkey:
    #!/usr/bin/env bash
    set -euo pipefail

    key_file="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"
    key_file="${key_file/#\~/$HOME}"

    if [[ ! -f "$key_file" ]]; then
        echo "No age key found at $key_file"
        echo ""
        echo "Generate one with:"
        echo "  mkdir -p ~/.config/sops/age"
        echo "  age-keygen -o ~/.config/sops/age/keys.txt"
        echo "  chmod 600 ~/.config/sops/age/keys.txt"
        exit 1
    fi

    pubkey=$(grep "public key" "$key_file" 2>/dev/null | cut -d: -f2 | tr -d ' ' || echo "")

    if [[ -n "$pubkey" ]]; then
        echo ""
        echo "Your public key (share this with team admin):"
        echo ""
        echo "  $pubkey"
        echo ""
    else
        echo "Could not extract public key from $key_file"
        exit 1
    fi

# Generate a new age keypair
generate-key:
    #!/usr/bin/env bash
    set -euo pipefail

    key_file="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"
    key_file="${key_file/#\~/$HOME}"

    if [[ -f "$key_file" ]]; then
        echo "Key already exists at $key_file"
        echo ""
        echo "Your public key:"
        grep "public key" "$key_file" | cut -d: -f2 | tr -d ' '
        echo ""
        echo "To generate a NEW key, first backup and remove the existing one."
        exit 0
    fi

    mkdir -p "$(dirname "$key_file")"
    age-keygen -o "$key_file"
    chmod 600 "$key_file"

    echo ""
    echo "Key generated at: $key_file"
    echo ""
    echo "Your public key (share this with team admin):"
    grep "public key" "$key_file" | cut -d: -f2 | tr -d ' '
    echo ""
    echo "IMPORTANT: Back up your private key securely!"

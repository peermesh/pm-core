# ==============================================================
# Matrix Synapse Environment Configuration
# ==============================================================
# Copy this file to .env and configure for your deployment
#
# Usage:
#   cp .env.example .env
#   nano .env
# ==============================================================

# ==============================================================
# Required Configuration
# ==============================================================

# Your domain (used by Traefik for routing)
DOMAIN=example.com

# Matrix server name (this becomes part of user IDs: @user:matrix.example.com)
# IMPORTANT: Once set and users are created, this CANNOT be changed
SYNAPSE_SERVER_NAME=matrix.example.com

# Report anonymous statistics to matrix.org
# Set to "yes" to help the Matrix project (optional)
SYNAPSE_REPORT_STATS=no

# ==============================================================
# Federation Configuration
# ==============================================================
# Matrix federation requires:
# 1. Port 8448 accessible from internet
# 2. Valid TLS certificate (Traefik handles this)
# 3. DNS SRV record OR .well-known delegation
#
# For SRV record:
#   _matrix._tcp.example.com  SRV  10 5 443 matrix.example.com
#
# For .well-known (serve at https://example.com/.well-known/matrix/server):
#   {"m.server": "matrix.example.com:443"}

# ==============================================================
# OIDC Configuration
# ==============================================================
# Configured in homeserver.yaml
# Requires matching client in Authelia configuration
#
# See D3.4-AUTHENTICATION.md for Authelia OIDC client setup

# ==============================================================
# Secrets Checklist
# ==============================================================
# Ensure these secret files exist before starting:
#
# Required:
#   ./secrets/synapse_db_password              - PostgreSQL password
#   ./secrets/synapse_signing_key              - Server signing key
#   ./secrets/synapse_registration_shared_secret - Admin registration
#   ./secrets/oidc_client_matrix               - OIDC client secret
#
# Generate secrets:
#   openssl rand -base64 32 > secrets/synapse_db_password
#   docker run --rm matrixdotorg/synapse:latest generate_signing_key > secrets/synapse_signing_key
#   openssl rand -base64 32 > secrets/synapse_registration_shared_secret
#   openssl rand -base64 32 > secrets/oidc_client_matrix
#
# ==============================================================

# ==============================================================
# Configuration Files Required
# ==============================================================
# Before starting, generate Synapse configuration:
#
#   mkdir -p examples/matrix/config
#   docker run --rm \
#     -v $(pwd)/examples/matrix/config:/data \
#     -e SYNAPSE_SERVER_NAME=matrix.example.com \
#     -e SYNAPSE_REPORT_STATS=no \
#     matrixdotorg/synapse:latest generate
#
# Then customize homeserver.yaml for:
# - PostgreSQL connection
# - OIDC configuration
# - Federation settings
# - TURN server (if using)
#
# ==============================================================

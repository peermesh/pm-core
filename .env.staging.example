# ==============================================================
# PeerMesh Core - STAGING Environment
# ==============================================================
# Copy to .env for staging deployment:
#   ./launch_docker_lab_core.sh env staging
#
# Characteristics:
#   - Domain: staging.peers.social (or your staging subdomain)
#   - TLS: Let's Encrypt staging CA (real certs, no rate limits)
#   - Logging: INFO level
#   - Profiles: Production-like, with dev tools enabled
# ==============================================================

# ==============================================================
# REQUIRED CONFIGURATION
# ==============================================================

DOMAIN=staging.peers.social
ADMIN_EMAIL=admin@peers.social

# ==============================================================
# PROFILE ACTIVATION
# ==============================================================
# Staging mirrors production profiles plus dev tools for debugging.
COMPOSE_PROFILES=postgresql,redis

# ==============================================================
# RESOURCE PROFILE
# ==============================================================
# core: standard deployment matching typical VPS sizing
RESOURCE_PROFILE=core

# ==============================================================
# TRAEFIK CONFIGURATION
# ==============================================================

TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_DASHBOARD_PORT=8080

# REQUIRED: Generate with: htpasswd -nb admin your_secure_password
TRAEFIK_DASHBOARD_AUTH=

# TLS: Let's Encrypt staging CA — issues real certificates but
# browsers will show warnings. Does NOT count against LE rate limits.
# Remove or leave empty to use production LE.
TRAEFIK_ACME_CASERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# ==============================================================
# CORE DASHBOARD
# ==============================================================

DOCKERLAB_USERNAME=admin
DOCKERLAB_PASSWORD=
DOCKERLAB_DEMO_MODE=false

# ==============================================================
# POSTGRESQL TUNING (when postgresql profile enabled)
# ==============================================================

POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE=768MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_MEMORY_LIMIT=1G
POSTGRES_MEMORY_RESERVATION=512M

# ==============================================================
# REDIS TUNING (when redis profile enabled)
# ==============================================================

REDIS_MAXMEMORY=128mb
REDIS_MEMORY_LIMIT=256M
REDIS_MEMORY_RESERVATION=64M

# REQUIRED: Generate with: openssl rand -hex 32
REDIS_PASSWORD=

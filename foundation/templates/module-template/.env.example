# ==============================================================
# Module Template - Environment Configuration
# ==============================================================
# Copy this file to .env and customize for your deployment.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#
# CUSTOMIZE: Replace these placeholder variables with your
# module's actual configuration.
# ==============================================================

# ==============================================================
# Foundation Variables (copied from foundation .env)
# ==============================================================
# These values come from the foundation-level .env file.
# Do NOT hardcode domain values -- use this variable in Traefik
# labels and any configuration that references the deployment domain.
DOMAIN=example.com

# ==============================================================
# Module Configuration
# ==============================================================
MY_MODULE_EXAMPLE_SETTING=default-value

# Secret values (prefer file-based secrets over env vars)
# MY_MODULE_API_KEY=your-api-key-here

#!/usr/bin/env bash
#
# PeerMesh Foundation CLI
#
# Main entry point for all foundation commands. This script provides a unified
# interface for managing the PeerMesh module foundation system.
#
# Usage:
#   foundation <command> [subcommand] [options]
#
# Commands:
#   migrate     Manage foundation version migrations
#   module      Module lifecycle management
#   config      Configuration utilities
#   version     Show foundation version
#   help        Show help for a command
#
# Options:
#   -h, --help      Show this help message
#   --version       Show foundation version
#   -q, --quiet     Suppress non-essential output
#   --json          Output in JSON format where supported
#
# Exit codes:
#   0 - Success
#   1 - Command failed
#   2 - Invalid arguments or configuration
#   3 - Missing dependencies
#
# Examples:
#   foundation version                      Show foundation version
#   foundation migrate status               Show migration status
#   foundation migrate up                   Apply pending migrations
#   foundation module list                  List installed modules
#   foundation config validate              Validate configuration
#
# Environment:
#   FOUNDATION_DIR        Path to foundation directory (auto-detected)
#   FOUNDATION_DATA_DIR   Path to foundation data directory
#
# For more information, see the foundation README.md
#

set -euo pipefail

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Foundation directory (parent of bin/)
FOUNDATION_DIR="${FOUNDATION_DIR:-$(dirname "$SCRIPT_DIR")}"

# Output options
OUTPUT_JSON=false
QUIET=false

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# =============================================================================
# Logging Functions
# =============================================================================

log_info() {
    if [[ "$OUTPUT_JSON" == "false" && "$QUIET" == "false" ]]; then
        printf "%s\n" "$1"
    fi
}

log_error() {
    if [[ "$OUTPUT_JSON" == "false" ]]; then
        printf "%bError:%b %s\n" "$RED" "$NC" "$1" >&2
    fi
}

log_warn() {
    if [[ "$OUTPUT_JSON" == "false" && "$QUIET" == "false" ]]; then
        printf "%bWarning:%b %s\n" "$YELLOW" "$NC" "$1" >&2
    fi
}

# =============================================================================
# Help Functions
# =============================================================================

show_help() {
    cat << 'EOF'
PeerMesh Foundation CLI

Usage:
  foundation <command> [subcommand] [options]

Commands:
  migrate         Manage foundation version migrations
    status        Show current version and pending migrations
    up            Apply migrations to upgrade
    down          Rollback to a previous version
    history       Show migration history
    version       Show current foundation version

  module          Module lifecycle management
    list          List installed modules
    info          Show module details
    validate      Validate module manifest
    install       Install a module (placeholder)
    uninstall     Uninstall a module (placeholder)

  config          Configuration utilities
    validate      Validate configuration files
    env           Generate environment files
    show          Show current configuration

  version         Show foundation version
  help            Show help for a command

Global Options:
  -h, --help      Show this help message
  --version       Show foundation version
  -q, --quiet     Suppress non-essential output
  --json          Output in JSON format where supported

Examples:
  foundation version                  Show foundation version
  foundation migrate status           Show migration status
  foundation migrate up               Apply pending migrations
  foundation module list              List installed modules
  foundation config validate          Validate configuration

Environment:
  FOUNDATION_DIR        Path to foundation directory
  FOUNDATION_DATA_DIR   Path to foundation data directory

For detailed command help:
  foundation help <command>
  foundation <command> --help
EOF
}

show_command_help() {
    local cmd="$1"
    case "$cmd" in
        migrate)
            if [[ -x "$SCRIPT_DIR/migrate" ]]; then
                "$SCRIPT_DIR/migrate" --help
            else
                cat << 'EOF'
Usage: foundation migrate <subcommand> [options]

Manage foundation version migrations.

Subcommands:
  status          Show current version and pending migrations
  up [version]    Apply migrations up to version (default: latest)
  down <version>  Rollback to a specific version
  history         Show migration history
  version         Show current foundation version

Options:
  --dry-run       Show what would be done without executing
  --force         Run even if migrations appear applied
  --json          Output in JSON format
  -h, --help      Show this help message

Examples:
  foundation migrate status           Show current state
  foundation migrate up               Apply all pending migrations
  foundation migrate up 1.1.0         Migrate up to version 1.1.0
  foundation migrate down 1.0.0       Rollback to version 1.0.0
  foundation migrate history          Show migration history
EOF
            fi
            ;;
        module)
            cat << 'EOF'
Usage: foundation module <subcommand> [options]

Module lifecycle management.

Subcommands:
  list            List installed modules
  info <id>       Show detailed module information
  validate <path> Validate a module manifest
  install <path>  Install a module (placeholder)
  uninstall <id>  Uninstall a module (placeholder)

Options:
  --json          Output in JSON format
  -h, --help      Show this help message

Examples:
  foundation module list              List all modules
  foundation module info my-module    Show module details
  foundation module validate ./my-mod Validate module manifest
EOF
            ;;
        config)
            cat << 'EOF'
Usage: foundation config <subcommand> [options]

Configuration utilities.

Subcommands:
  validate        Validate configuration against schemas
  env <path>      Generate .env files from module config
  show            Show current foundation configuration

Options:
  --json          Output in JSON format
  -h, --help      Show this help message

Examples:
  foundation config validate          Validate all configuration
  foundation config env ./my-module   Generate .env.example
  foundation config show              Show current config
EOF
            ;;
        version)
            cat << 'EOF'
Usage: foundation version [options]

Show the current foundation version.

Options:
  --json          Output in JSON format

The version is read from the VERSION file in the foundation directory.
EOF
            ;;
        *)
            show_help
            ;;
    esac
}

# =============================================================================
# Version Command
# =============================================================================

get_version() {
    local version_file="$FOUNDATION_DIR/VERSION"
    if [[ -f "$version_file" ]]; then
        cat "$version_file" | tr -d '[:space:]'
    else
        echo "0.0.0"
    fi
}

cmd_version() {
    local version
    version=$(get_version)

    if [[ "$OUTPUT_JSON" == "true" ]]; then
        jq -n \
            --arg version "$version" \
            --arg foundationDir "$FOUNDATION_DIR" \
            '{
                version: $version,
                foundationDir: $foundationDir
            }'
    else
        echo "$version"
    fi
}

# =============================================================================
# Module Commands
# =============================================================================

cmd_module() {
    local subcommand="${1:-list}"
    shift || true

    local modules_dir
    modules_dir="$(dirname "$FOUNDATION_DIR")/modules"

    case "$subcommand" in
        list)
            if [[ ! -d "$modules_dir" ]]; then
                if [[ "$OUTPUT_JSON" == "true" ]]; then
                    echo '{"modules": [], "count": 0}'
                else
                    log_info "No modules directory found"
                fi
                return 0
            fi

            local modules=()
            for manifest in "$modules_dir"/*/module.json; do
                if [[ -f "$manifest" ]]; then
                    local id name version
                    id=$(jq -r '.id' "$manifest" 2>/dev/null || basename "$(dirname "$manifest")")
                    name=$(jq -r '.name // .id' "$manifest" 2>/dev/null || echo "$id")
                    version=$(jq -r '.version // "unknown"' "$manifest" 2>/dev/null || echo "unknown")
                    modules+=("$id|$name|$version")
                fi
            done

            if [[ "$OUTPUT_JSON" == "true" ]]; then
                local modules_json
                modules_json=$(printf '%s\n' "${modules[@]}" | while IFS='|' read -r id name version; do
                    jq -n --arg id "$id" --arg name "$name" --arg version "$version" \
                        '{"id": $id, "name": $name, "version": $version}'
                done | jq -s '.')

                jq -n --argjson modules "$modules_json" --argjson count "${#modules[@]}" \
                    '{"modules": $modules, "count": $count}'
            else
                if [[ ${#modules[@]} -eq 0 ]]; then
                    log_info "No modules installed"
                else
                    printf "\n%b%-20s %-30s %s%b\n" "$BOLD" "ID" "NAME" "VERSION" "$NC"
                    printf "%-20s %-30s %s\n" "---" "----" "-------"
                    for module in "${modules[@]}"; do
                        IFS='|' read -r id name version <<< "$module"
                        printf "%-20s %-30s %s\n" "$id" "$name" "$version"
                    done
                    printf "\nTotal: %d module(s)\n" "${#modules[@]}"
                fi
            fi
            ;;
        info)
            local module_id="${1:-}"
            if [[ -z "$module_id" ]]; then
                log_error "Module ID required"
                echo "Usage: foundation module info <module-id>" >&2
                return 2
            fi

            local manifest="$modules_dir/$module_id/module.json"
            if [[ ! -f "$manifest" ]]; then
                log_error "Module not found: $module_id"
                return 2
            fi

            if [[ "$OUTPUT_JSON" == "true" ]]; then
                cat "$manifest"
            else
                printf "\n%bModule: %s%b\n\n" "$BOLD" "$module_id" "$NC"
                jq -r '
                    "  ID:          \(.id // "n/a")",
                    "  Name:        \(.name // "n/a")",
                    "  Version:     \(.version // "n/a")",
                    "  Description: \(.description // "n/a")",
                    "",
                    "  Foundation:",
                    "    Min Version: \(.foundation.minVersion // "n/a")",
                    "    Max Version: \(.foundation.maxVersion // "n/a")"
                ' "$manifest"
            fi
            ;;
        validate)
            local module_path="${1:-}"
            if [[ -z "$module_path" ]]; then
                log_error "Module path required"
                echo "Usage: foundation module validate <path>" >&2
                return 2
            fi

            local manifest
            if [[ -f "$module_path/module.json" ]]; then
                manifest="$module_path/module.json"
            elif [[ -f "$module_path" ]]; then
                manifest="$module_path"
            else
                log_error "Module manifest not found: $module_path"
                return 2
            fi

            # Basic JSON validation
            if ! jq empty "$manifest" 2>/dev/null; then
                if [[ "$OUTPUT_JSON" == "true" ]]; then
                    jq -n '{"valid": false, "error": "Invalid JSON"}'
                else
                    log_error "Invalid JSON in manifest"
                fi
                return 1
            fi

            # Required fields check
            local errors=()
            local id version foundation

            id=$(jq -r '.id // empty' "$manifest")
            version=$(jq -r '.version // empty' "$manifest")
            foundation=$(jq -r '.foundation.minVersion // empty' "$manifest")

            [[ -z "$id" ]] && errors+=("Missing required field: id")
            [[ -z "$version" ]] && errors+=("Missing required field: version")
            [[ -z "$foundation" ]] && errors+=("Missing required field: foundation.minVersion")

            if [[ ${#errors[@]} -gt 0 ]]; then
                if [[ "$OUTPUT_JSON" == "true" ]]; then
                    local errors_json
                    errors_json=$(printf '%s\n' "${errors[@]}" | jq -R . | jq -s .)
                    jq -n --argjson errors "$errors_json" '{"valid": false, "errors": $errors}'
                else
                    log_error "Validation failed:"
                    for err in "${errors[@]}"; do
                        printf "  - %s\n" "$err"
                    done
                fi
                return 1
            fi

            if [[ "$OUTPUT_JSON" == "true" ]]; then
                jq -n '{"valid": true}'
            else
                printf "%b✓%b Module manifest is valid\n" "$GREEN" "$NC"
            fi
            ;;
        install|uninstall)
            log_warn "Module $subcommand is a placeholder - not yet implemented"
            return 0
            ;;
        *)
            log_error "Unknown module subcommand: $subcommand"
            show_command_help "module"
            return 2
            ;;
    esac
}

# =============================================================================
# Config Commands
# =============================================================================

cmd_config() {
    local subcommand="${1:-show}"
    shift || true

    case "$subcommand" in
        show)
            if [[ "$OUTPUT_JSON" == "true" ]]; then
                jq -n \
                    --arg foundationDir "$FOUNDATION_DIR" \
                    --arg dataDir "${FOUNDATION_DATA_DIR:-$(dirname "$FOUNDATION_DIR")/.foundation}" \
                    --arg version "$(get_version)" \
                    '{
                        foundationDir: $foundationDir,
                        dataDir: $dataDir,
                        version: $version
                    }'
            else
                printf "\n%bFoundation Configuration%b\n\n" "$BOLD" "$NC"
                printf "  Foundation Dir:  %s\n" "$FOUNDATION_DIR"
                printf "  Data Dir:        %s\n" "${FOUNDATION_DATA_DIR:-$(dirname "$FOUNDATION_DIR")/.foundation}"
                printf "  Version:         %s\n" "$(get_version)"
            fi
            ;;
        validate)
            log_info "Validating configuration..."

            local errors=0

            # Check VERSION file
            if [[ ! -f "$FOUNDATION_DIR/VERSION" ]]; then
                log_warn "VERSION file not found"
                ((errors++)) || true
            fi

            # Check schemas directory
            if [[ ! -d "$FOUNDATION_DIR/schemas" ]]; then
                log_warn "schemas/ directory not found"
                ((errors++)) || true
            fi

            # Check required schemas
            local required_schemas=("module.schema.json" "lifecycle.schema.json" "event.schema.json")
            for schema in "${required_schemas[@]}"; do
                if [[ ! -f "$FOUNDATION_DIR/schemas/$schema" ]]; then
                    log_warn "Missing schema: $schema"
                    ((errors++)) || true
                fi
            done

            if [[ $errors -eq 0 ]]; then
                if [[ "$OUTPUT_JSON" == "true" ]]; then
                    jq -n '{"valid": true, "errors": 0}'
                else
                    printf "%b✓%b Configuration is valid\n" "$GREEN" "$NC"
                fi
            else
                if [[ "$OUTPUT_JSON" == "true" ]]; then
                    jq -n --argjson errors "$errors" '{"valid": false, "errors": $errors}'
                else
                    log_error "Configuration has $errors issue(s)"
                fi
                return 1
            fi
            ;;
        env)
            local module_path="${1:-}"
            if [[ -z "$module_path" ]]; then
                log_error "Module path required"
                echo "Usage: foundation config env <module-path>" >&2
                return 2
            fi

            # Delegate to env-generate.sh
            local env_script="$FOUNDATION_DIR/lib/env-generate.sh"
            if [[ -x "$env_script" ]]; then
                shift || true
                "$env_script" "$module_path" "$@"
            else
                log_error "env-generate.sh not found or not executable"
                return 3
            fi
            ;;
        *)
            log_error "Unknown config subcommand: $subcommand"
            show_command_help "config"
            return 2
            ;;
    esac
}

# =============================================================================
# Main
# =============================================================================

main() {
    local command=""
    local args=()

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --json)
                OUTPUT_JSON=true
                shift
                ;;
            -q|--quiet)
                QUIET=true
                shift
                ;;
            --version)
                cmd_version
                exit 0
                ;;
            -h|--help)
                if [[ -z "$command" ]]; then
                    show_help
                else
                    show_command_help "$command"
                fi
                exit 0
                ;;
            -*)
                # Pass unknown options to subcommands
                args+=("$1")
                shift
                ;;
            *)
                if [[ -z "$command" ]]; then
                    command="$1"
                else
                    args+=("$1")
                fi
                shift
                ;;
        esac
    done

    # Check foundation directory
    if [[ ! -d "$FOUNDATION_DIR" ]]; then
        log_error "Foundation directory not found: $FOUNDATION_DIR"
        exit 2
    fi

    # Execute command
    case "$command" in
        ""|help)
            if [[ ${#args[@]} -gt 0 ]]; then
                show_command_help "${args[0]}"
            else
                show_help
            fi
            ;;
        version)
            cmd_version
            ;;
        migrate)
            # Delegate to migrate script
            local migrate_script="$SCRIPT_DIR/migrate"
            if [[ -x "$migrate_script" ]]; then
                local migrate_args=()
                [[ "$OUTPUT_JSON" == "true" ]] && migrate_args+=("--json")
                [[ "$QUIET" == "true" ]] && migrate_args+=("--quiet")
                "$migrate_script" "${args[@]}" "${migrate_args[@]}"
            else
                log_error "migrate script not found: $migrate_script"
                exit 3
            fi
            ;;
        module)
            cmd_module "${args[@]}"
            ;;
        config)
            cmd_config "${args[@]}"
            ;;
        *)
            log_error "Unknown command: $command"
            show_help
            exit 2
            ;;
    esac
}

main "$@"

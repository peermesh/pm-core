# ==============================================================
# Universal Manifest Module - Environment Configuration
# ==============================================================
# Copy to .env and customize:
#   cp .env.example .env
# ==============================================================

# Required: The domain where Docker Lab is hosted
DOMAIN=example.com

# Subdomain for the UM resolver (um.${DOMAIN})
UM_SUBDOMAIN=um

# Node.js environment (production, development, test)
NODE_ENV=production

# HTTP server port (inside container)
UM_PORT=4200

# PostgreSQL connection
UM_DB_HOST=postgres
UM_DB_PORT=5432
UM_DB_NAME=universal_manifest
UM_DB_USER=um
# Password: use file-based secret (secrets/um_db_password)
# For local dev, set UM_DB_PASSWORD here instead
# UM_DB_PASSWORD=

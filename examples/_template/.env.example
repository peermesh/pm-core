# ==============================================================
# Application Template - Environment Configuration
# ==============================================================
# Template for new application environment files
#
# Instructions:
#   1. Copy to examples/myapp/.env.example
#   2. Replace MYAPP with your application name
#   3. Add application-specific variables
#   4. Document each variable clearly
# ==============================================================

# ==============================================================
# Required Configuration
# ==============================================================

# Your domain (used by Traefik for routing)
DOMAIN=example.com

# Database password (must match secrets/myapp_db_password)
MYAPP_DB_PASSWORD=

# ==============================================================
# Application Settings
# ==============================================================

# Add your application-specific settings here
# MYAPP_SETTING_1=value
# MYAPP_SETTING_2=value

# ==============================================================
# Optional Configuration
# ==============================================================

# Debug mode (disable in production)
# MYAPP_DEBUG=false

# Log level
# MYAPP_LOG_LEVEL=info

# ==============================================================
# Resource Profile
# ==============================================================

# Memory profile (affects resource limits)
# Options: core (smaller), full (larger)
# RESOURCE_PROFILE=full

# ==============================================================
# Secrets Checklist
# ==============================================================
# Ensure these secret files exist before starting:
#
# Required:
#   ./secrets/myapp_db_password  - Database password
#
# Optional:
#   ./secrets/myapp_secret       - Application secret key
#   ./secrets/oidc_client_myapp  - OIDC client secret
#
# Generate secrets:
#   openssl rand -base64 32 > secrets/myapp_db_password
#   chmod 600 secrets/myapp_db_password
#
# ==============================================================

# ==============================================================
# Database Configuration
# ==============================================================
# The database must be initialized before starting.
# Add initialization to the appropriate profile init script:
#
# For PostgreSQL (profiles/postgresql/init-scripts/01-init-databases.sh):
#   CREATE DATABASE myapp;
#   CREATE USER myapp WITH PASSWORD 'xxx';
#   GRANT ALL PRIVILEGES ON DATABASE myapp TO myapp;
#
# For MySQL (profiles/mysql/init-scripts/01-init-databases.sh):
#   CREATE DATABASE myapp;
#   CREATE USER 'myapp'@'%' IDENTIFIED BY 'xxx';
#   GRANT ALL PRIVILEGES ON myapp.* TO 'myapp'@'%';
#
# ==============================================================

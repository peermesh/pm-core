# ==============================================================
# Ghost CMS Environment Configuration
# ==============================================================
# Copy this file to .env and configure for your deployment
#
# Usage:
#   cp .env.example .env
#   nano .env
# ==============================================================

# ==============================================================
# Required Configuration
# ==============================================================

# Your domain (used by Traefik for routing)
DOMAIN=example.com

# Full URL to Ghost (must include https:// and match Traefik host)
GHOST_URL=https://ghost.example.com

# ==============================================================
# Email Configuration (Required for member features)
# ==============================================================
# Ghost uses email for:
# - Magic link authentication
# - Member newsletters
# - Staff notifications
#
# Options:
# - Direct: Use server's sendmail (development only)
# - SMTP: Production mail service

# Mail transport type (Direct, SMTP)
GHOST_MAIL_TRANSPORT=SMTP

# SMTP server configuration
GHOST_MAIL_HOST=smtp.sendgrid.net
GHOST_MAIL_PORT=587
GHOST_MAIL_USER=apikey
# Password goes in secrets/ghost_mail_password

# From address for emails
GHOST_MAIL_FROM=noreply@example.com

# ==============================================================
# Optional Configuration
# ==============================================================

# Resource profile (affects memory limits)
# Options: core (256M), full (512M)
# RESOURCE_PROFILE=full

# ==============================================================
# Secrets Checklist
# ==============================================================
# Ensure these secret files exist before starting:
#
# Required:
#   ./secrets/ghost_db_password    - Ghost MySQL user password
#   ./secrets/mysql_root_password  - MySQL root password (from profile)
#
# Optional:
#   ./secrets/ghost_mail_password  - SMTP password/API key
#
# Generate database password:
#   openssl rand -base64 32 > secrets/ghost_db_password
#   chmod 600 secrets/ghost_db_password
#
# ==============================================================

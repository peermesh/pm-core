# ==============================================================
# Backup Profile Configuration
# ==============================================================
# Copy this file to .env or add these variables to your existing .env
# Documentation: profiles/backup/PROFILE-SPEC.md
# ==============================================================

# --------------------------------------------------------------
# Local Backup Configuration
# --------------------------------------------------------------

# Local backup destination
BACKUP_LOCAL_PATH=/var/backups/pmdl

# Volume prefix filter (backup volumes matching this prefix)
VOLUME_PREFIX=pmdl_

# Container names (override if using custom names)
POSTGRES_CONTAINER_NAME=pmdl_postgres

# --------------------------------------------------------------
# Retention Policy
# --------------------------------------------------------------

# Number of daily backups to keep
BACKUP_RETENTION_DAILY=7

# Number of weekly backups to keep
BACKUP_RETENTION_WEEKLY=4

# Number of monthly backups to keep
BACKUP_RETENTION_MONTHLY=3

# --------------------------------------------------------------
# Restic Configuration (Optional)
# --------------------------------------------------------------

# Restic repository URL
# Examples:
#   Local:  /var/backups/pmdl/restic
#   S3:     s3:https://s3.example.com/bucket/path
#   SFTP:   sftp:user@host:/path
#   REST:   rest:https://user:pass@host:8000/path
BACKUP_RESTIC_REPOSITORY=

# Restic password is stored in secrets/restic_password

# --------------------------------------------------------------
# S3/MinIO Configuration (Optional)
# --------------------------------------------------------------

# S3-compatible endpoint URL (include https://)
# Examples:
#   MinIO:     https://minio.example.com
#   Backblaze: https://s3.us-west-000.backblazeb2.com
#   Wasabi:    https://s3.wasabisys.com
BACKUP_S3_ENDPOINT=

# S3 bucket name
BACKUP_S3_BUCKET=

# S3 credentials are stored in secrets/s3_access_key and secrets/s3_secret_key

# --------------------------------------------------------------
# Encryption Configuration (Optional)
# --------------------------------------------------------------

# Age public key for encrypting backups
# Generate with: age-keygen
# Example: age1ql3z7hjy54pw3hyww5ayf...
BACKUP_AGE_RECIPIENT=

# Age private key is stored in secrets/age_key (for restore operations)

# --------------------------------------------------------------
# Advanced Configuration
# --------------------------------------------------------------

# Bandwidth limit for off-site sync (KB/s, 0 = unlimited)
# BANDWIDTH_LIMIT=0

# Custom backup schedule (cron format)
# Default: 2:00 AM for PostgreSQL, 3:00 AM for volumes
# BACKUP_POSTGRES_SCHEDULE="0 2 * * *"
# BACKUP_VOLUMES_SCHEDULE="0 3 * * *"
